                                                <%= grandTidakHadir > 0 ? grandTidakHadir + 'x' : '-' %>
                                            </span>
                                        </td>

                                        <% 
                                            // Empty cells for Saturday columns
                                            if (typeof saturdays !== 'undefined' && Array.isArray(saturdays)) {
                                                saturdays.forEach(d => {
                                        %>
                                            <td class="px-6 py-4"></td>
                                        <%      });
                                            } %>
                                        
                                        <td class="hidden lg:table-cell px-1 py-4 whitespace-nowrap text-center text-sm bg-green-100 bg-green-medium border-l-2 border-green-400 lg:sticky lg:right-[270px] z-10 w-[90px] min-w-[90px] max-w-[90px]">
                                            <span class="font-bold text-[10px] sm:text-sm text-gray-900 dark:text-gray-100">
                                                <%= grandTotalDenda > 0 ? 'Rp ' + grandTotalDenda.toLocaleString('id-ID') : '-' %>
                                            </span>
