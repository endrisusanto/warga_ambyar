                                            <div class="text-[10px] sm:text-sm font-bold text-gray-900 dark:text-gray-100 uppercase">
                                                GRAND TOTAL
                                            </div>
                                        </td>
                                        <% 
                                            // Calculate grand totals
                                            let grandTotalDenda = 0;
                                            let grandSudahBayar = 0;
                                            let grandTerhutang = 0;
                                            let grandTidakHadir = 0;
                                            
                                            Object.keys(matrix).forEach(wId => {
                                                const row = matrix[wId];
                                                if (typeof saturdays !== 'undefined' && Array.isArray(saturdays)) {
                                                    saturdays.forEach(d => {
