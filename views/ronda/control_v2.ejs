<%- include('../partials/head') %>
    <style>
        /* Custom soft colors for dark mode sticky columns */
        .dark .bg-gray-soft { background-color: rgb(75 75 75); }
        .dark .bg-gray-medium { background-color: rgb(60 60 60); }
        
        .dark .bg-green-soft { background-color: rgb(67 94 77); }
        .dark .bg-blue-soft { background-color: rgb(67 84 94); }
        .dark .bg-red-soft { background-color: rgb(94 67 67); }
        .dark .bg-orange-soft { background-color: rgb(94 80 67); }
        
        .dark .bg-green-medium { background-color: rgb(45 75 55); }
        .dark .bg-blue-medium { background-color: rgb(45 65 75); }
        .dark .bg-red-medium { background-color: rgb(75 45 45); }
        .dark .bg-orange-medium { background-color: rgb(75 60 45); }
        
        /* Dropdown Contrast Fix for Dark Mode */
        .dark select option {
            background-color: #1f2937;
            color: #f3f4f6;
        }
    </style>
    <%- include('../partials/navbar', { useWideContainer: true, user: user }) %>

        <div class="mx-auto py-6 px-2 sm:px-4 lg:px-6">
            <div class="py-6">
                <div class="flex flex-col md:flex-row justify-between items-center mb-6 gap-4">
                    <div class="flex items-center space-x-4">
                        <a href="/ronda" class="text-gray-600 dark:text-gray-400 hover:text-gray-200 transition-colors">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                            </svg>
                        </a>
                        <h1 class="text-3xl font-bold text-gray-900 dark:text-gray-100 flex items-center gap-3">
                            <span class="text-4xl">📋</span>
                            Control Absensi Ronda
                        </h1>
                    </div>
<script src="https://cdn.jsdelivr.net/npm/qrcode@1.5.1/build/qrcode.min.js"></script>

                    <div class="flex flex-wrap justify-end gap-3">
                        <!-- Export Button Wrapper -->
                        <div class="glass-card p-3 flex items-center">
                            <a href="/ronda/export-control?year=<%= year %>"
                                class="flex items-center gap-2 px-3 py-2 text-sm font-bold text-green-600 dark:text-green-400 bg-green-50 dark:bg-green-900/20 rounded-lg hover:bg-green-100 dark:hover:bg-green-900/30 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                                </svg>
                                Excel
                            </a>

                            <button onclick="exportToCSV()"
                                class="flex items-center gap-2 px-3 py-2 text-sm font-bold text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/20 rounded-lg hover:bg-blue-100 dark:hover:bg-blue-900/30 transition-colors">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                </svg>
                                CSV
                            </button>
                        </div>

                        <div class="glass-card p-4 flex items-center justify-between">
                            <% let prevY=parseInt(year) - 1;
                                let nextY=parseInt(year) + 1; %>
    
                                <a href="/ronda/control?year=<%= prevY %>"
                                    class="p-2 bg-gray-100 dark:bg-white/10 hover:bg-gray-200 dark:hover:bg-white/20 rounded-lg text-gray-600 dark:text-gray-300 transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M15 19l-7-7 7-7"></path>
                                    </svg>
                                </a>
    
                                <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100">
                                    Tahun <%= year %>
                                </h2>
                                
                                <a href="/ronda/control?year=<%= nextY %>"
                                    class="p-2 bg-gray-100 dark:bg-white/10 hover:bg-gray-200 dark:hover:bg-white/20 rounded-lg text-gray-600 dark:text-gray-300 transition-colors">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </a>
                        </div>
                    </div>
                </div>

                <div class="glass-card p-0 overflow-hidden mx-2 sm:mx-4 lg:mx-6">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-white/10">
                            <thead class="bg-gray-100 dark:bg-white/5 backdrop-blur-xl">
                                <tr>
                                    <th scope="col" onclick="sortTable(0, 'string')"
                                        class="px-2 py-2 sm:px-6 sm:py-3 text-left text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider sticky left-0 bg-gray-100 bg-gray-soft z-20 border-r border-gray-300 dark:border-gray-700 cursor-pointer group hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
                                        <div class="flex items-center justify-between">
                                            Warga
                                            <span class="sort-icon ml-1 text-gray-900 dark:text-white">↑</span>
                                        </div>
                                    </th>
                                    %>
                                    <th scope="col" onclick="sortTable(1, 'number')"
                                        class="table-cell lg:hidden px-1 py-3 text-center text-[10px] font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider bg-green-100 bg-green-soft w-[90px] min-w-[90px] max-w-[90px] cursor-pointer group hover:brightness-95 transition-all">
                                        <div class="flex flex-col items-center justify-center leading-tight">
                                            <span>Total</span>
                                            <span>Denda</span>
                                            <span class="sort-icon text-gray-400/70 group-hover:text-gray-600 mt-0.5">⇵</span>
                                        </div>
                                    </th>
                                    <th scope="col" onclick="sortTable(2, 'number')"
                                        class="table-cell lg:hidden px-1 py-3 text-center text-[10px] font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider bg-blue-100 bg-blue-soft w-[90px] min-w-[90px] max-w-[90px] cursor-pointer group hover:brightness-95 transition-all">
                                        <div class="flex flex-col items-center justify-center leading-tight">
                                            <span>Sudah</span>
                                            <span>Bayar</span>
                                            <span class="sort-icon text-gray-400/70 group-hover:text-gray-600 mt-0.5">⇵</span>
                                        </div>
                                    </th>
                                    <th scope="col" onclick="sortTable(3, 'number')"
                                        class="table-cell lg:hidden px-1 py-3 text-center text-[10px] font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider bg-red-100 bg-red-soft w-[90px] min-w-[90px] max-w-[90px] cursor-pointer group hover:brightness-95 transition-all">
                                        <div class="flex flex-col items-center justify-center leading-tight">
                                            <span>Ter-</span>
                                            <span>hutang</span>
                                            <span class="sort-icon text-gray-400/70 group-hover:text-gray-600 mt-0.5">⇵</span>
                                        </div>
                                    </th>
                                    <th scope="col" onclick="sortTable(4, 'number')"
                                        class="table-cell lg:hidden px-1 py-3 text-center text-[10px] font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider bg-orange-100 bg-orange-soft w-[90px] min-w-[90px] max-w-[90px] cursor-pointer group hover:brightness-95 transition-all">
                                        <div class="flex flex-col items-center justify-center leading-tight">
                                            <span>Tidak</span>
                                            <span>Hadir</span>
                                            <span class="sort-icon text-gray-400/70 group-hover:text-gray-600 mt-0.5">⇵</span>
                                        </div>
                                    </th>
                                    <% 
                                    if (typeof saturdays !== 'undefined' && Array.isArray(saturdays)) {
                                        saturdays.forEach(d=> { 
                                            const isActive = (typeof activeSaturday !== 'undefined') ? d === activeSaturday : false;
                                            const isLibur = (typeof liburDatesArray !== 'undefined' && Array.isArray(liburDatesArray)) && liburDatesArray.includes(d);
                                    %>
                                        <th scope="col"
                                        class="px-2 py-2 sm:px-6 sm:py-3 text-center text-xs font-medium uppercase tracking-wider min-w-[120px] cursor-pointer transition-colors group relative
                                            <%= isLibur ? 'bg-red-50 dark:bg-red-900/20 text-red-500 dark:text-red-400 hover:bg-red-100 dark:hover:bg-red-900/30' : 'text-gray-700 dark:text-gray-300 hover:bg-orange-50 dark:hover:bg-orange-900/20' %>
                                            <%= isActive && !isLibur ? 'border-b-2 border-indigo-500 bg-indigo-50 dark:bg-indigo-900/40' : '' %>"
                                        onclick="showWeekMenu(event, '<%= d %>')">
                                        <div class="mb-1 flex items-center justify-center gap-1">
                                            Tgl <%= moment(d).format('DD') %>
                                            <% if (isLibur) { %><span class="text-red-400 text-[9px]">🚫</span><% } else { %><span class="opacity-0 group-hover:opacity-60 transition-opacity text-orange-400 text-[9px]">&#9881;</span><% } %>
                                        </div>
                                        <div class="text-[10px] <%= isLibur ? 'text-red-400 dark:text-red-500' : 'text-gray-500 dark:text-gray-400' %>">
                                            <%= moment(d).format('MMM') %>
                                        </div>
                                        <% if (isLibur) { %>
                                            <div class="text-[9px] font-bold text-white bg-red-500 dark:bg-red-600 mt-0.5 px-1.5 py-0.5 rounded-full inline-block">LIBUR</div>
                                        <% } else if (isActive) { %>
                                            <div class="text-[10px] font-bold text-indigo-600 dark:text-indigo-300 mt-0.5">● Next Schedule</div>
                                        <% } %>
                                        </th>
                                        <% })
                                        } %>
                                        
                                    <!-- Desktop Sticky Columns -->
                                    <th scope="col" onclick="sortTable(-4, 'number')"
                                        class="hidden lg:table-cell px-1 py-3 text-center text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider bg-green-100 bg-green-soft border-l-2 border-green-400 lg:sticky lg:right-[270px] z-10 w-[90px] min-w-[90px] max-w-[90px] cursor-pointer group hover:brightness-95 transition-all">
                                        <div class="flex flex-col items-center justify-center leading-tight">
                                            <span>Total</span>
                                            <span>Denda</span>
                                            <span class="sort-icon text-gray-400/70 group-hover:text-gray-600 mt-0.5">⇵</span>
                                        </div>
                                    </th>
                                    <th scope="col" onclick="sortTable(-3, 'number')"
                                        class="hidden lg:table-cell px-1 py-3 text-center text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider bg-blue-100 bg-blue-soft lg:sticky lg:right-[180px] z-10 w-[90px] min-w-[90px] max-w-[90px] cursor-pointer group hover:brightness-95 transition-all">
                                        <div class="flex flex-col items-center justify-center leading-tight">
                                            <span>Sudah</span>
                                            <span>Bayar</span>
                                            <span class="sort-icon text-gray-400/70 group-hover:text-gray-600 mt-0.5">⇵</span>
                                        </div>
                                    </th>
                                    <th scope="col" onclick="sortTable(-2, 'number')"
                                        class="hidden lg:table-cell px-1 py-3 text-center text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider bg-red-100 bg-red-soft lg:sticky lg:right-[90px] z-10 w-[90px] min-w-[90px] max-w-[90px] cursor-pointer group hover:brightness-95 transition-all">
                                        <div class="flex flex-col items-center justify-center leading-tight">
                                            <span>Ter-</span>
                                            <span>hutang</span>
                                            <span class="sort-icon text-gray-400/70 group-hover:text-gray-600 mt-0.5">⇵</span>
                                        </div>
                                    </th>
                                    <th scope="col" onclick="sortTable(-1, 'number')"
                                        class="hidden lg:table-cell px-1 py-3 text-center text-xs font-medium text-gray-700 dark:text-gray-300 uppercase tracking-wider bg-orange-100 bg-orange-soft lg:sticky lg:right-0 z-10 w-[90px] min-w-[90px] max-w-[90px] cursor-pointer group hover:brightness-95 transition-all">
                                        <div class="flex flex-col items-center justify-center leading-tight">
                                            <span>Tidak</span>
                                            <span>Hadir</span>
                                            <span class="sort-icon text-gray-400/70 group-hover:text-gray-600 mt-0.5">⇵</span>
                                        </div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="bg-gray-100 dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
                                <% Object.keys(matrix).forEach(wId=> {
                                    const row = matrix[wId];
                                    %>
                                    <tr class="hover:bg-gray-200 dark:hover:bg-gray-800 transition-colors">
                                        <td data-tim="<%= row.info.tim_ronda %>"
                                            class="px-2 py-2 sm:px-6 sm:py-4 whitespace-nowrap sticky left-0 bg-gray-100 bg-gray-soft z-20 border-r border-gray-300 dark:border-gray-700">
                                            <div class="flex items-center">
                                                <div>
                                                    <div class="text-xs sm:text-sm font-medium text-gray-900 dark:text-gray-100">
                                                        <%= row.info.nama %>
                                                    </div>
                                                    <div class="text-[10px] sm:text-xs text-gray-600 dark:text-gray-400">
                                                        Blok <%= row.info.blok %>-<%= row.info.nomor_rumah %>
                                                                <span
                                                                    class="ml-1 inline-flex items-center px-2 py-0.5 rounded text-[10px] font-medium bg-indigo-500/20 text-indigo-300 border border-indigo-400/30">
                                                                    Tim <%= row.info.tim_ronda || '-' %>
                                                                </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                        <% 
                                            // Calculate totals for this warga
                                            let totalDenda = 0;
                                            let sudahBayar = 0;
                                            let terhutang = 0;
                                            let tidakHadir = 0;
                                            
                                            if (typeof saturdays !== 'undefined' && Array.isArray(saturdays)) {
                                                saturdays.forEach(d => {
                                                    const cell = row.dates[d];
                                                    if (cell) {
                                                        if (cell.status === 'alpa') {
                                                            tidakHadir++;
                                                        }
                                                        if (cell.denda > 0) {
                                                            totalDenda += cell.denda;
                                                            if (cell.status_bayar === 'paid') {
                                                                sudahBayar += cell.denda;
                                                            } else {
                                                                terhutang += cell.denda;
                                                            }
                                                        }
                                                    }
                                                });
                                            }
                                        %>
                                        
                                        <td class="table-cell lg:hidden px-1 py-4 whitespace-nowrap text-center text-sm bg-green-50 bg-green-soft w-[90px] min-w-[90px] max-w-[90px]">
                                            <span class="font-bold text-gray-900 dark:text-gray-100 text-[10px] sm:text-xs">
                                                <%= totalDenda > 0 ? 'Rp ' + totalDenda.toLocaleString('id-ID') : '-' %>
                                            </span>
                                        </td>
                                        <td class="table-cell lg:hidden px-1 py-4 whitespace-nowrap text-center text-sm bg-blue-50 bg-blue-soft w-[90px] min-w-[90px] max-w-[90px]">
                                            <span class="font-bold <%= sudahBayar > 0 ? 'text-blue-600 dark:text-blue-400' : 'text-gray-400' %> text-[10px] sm:text-xs">
                                                <%= sudahBayar > 0 ? 'Rp ' + sudahBayar.toLocaleString('id-ID') : '-' %>
                                            </span>
                                        </td>
                                        <td class="table-cell lg:hidden px-1 py-4 whitespace-nowrap text-center text-sm bg-red-50 bg-red-soft w-[90px] min-w-[90px] max-w-[90px]">
                                            <span class="font-bold <%= terhutang > 0 ? 'text-red-600 dark:text-red-400' : 'text-gray-400' %> text-[10px] sm:text-xs">
                                                <%= terhutang > 0 ? 'Rp ' + terhutang.toLocaleString('id-ID') : '-' %>
                                            </span>
                                        </td>
                                        <td class="table-cell lg:hidden px-1 py-4 whitespace-nowrap text-center text-sm bg-orange-50 bg-orange-soft w-[90px] min-w-[90px] max-w-[90px]">
                                            <span class="font-bold <%= tidakHadir > 0 ? 'text-orange-600 dark:text-orange-400' : 'text-gray-400' %> text-[10px] sm:text-xs">
                                                <%= tidakHadir > 0 ? tidakHadir + 'x' : '-' %>
                                            </span>
                                        </td>

                                        <% 
                                            if (typeof saturdays !== 'undefined' && Array.isArray(saturdays)) {
                                                saturdays.forEach((d, satIndex)=> {
                                                const cell = row.dates[d];
                                                const isActiveColumn = (typeof activeSaturday !== 'undefined') ? d === activeSaturday : false;
                                                const isLiburColumn = (typeof liburDatesArray !== 'undefined' && Array.isArray(liburDatesArray)) && liburDatesArray.includes(d);
                                            
                                            let tdClasses = "px-1 py-2 sm:px-6 sm:py-4 whitespace-nowrap text-center text-sm relative ";
                                            
                                            // Libur column styling
                                            if (isLiburColumn) {
                                                tdClasses += "bg-red-50/60 dark:bg-red-900/10 border-x border-red-200 dark:border-red-800/30 ";
                                            } else if (isActiveColumn) {
                                                // Active column highlighting
                                                tdClasses += "bg-indigo-50 dark:bg-indigo-900/20 border-x-2 border-indigo-400 ";
                                            }
                                        %>
                                                    <td class="<%= tdClasses %>">
                                                        <div
                                                            class="relative z-10 inline-flex flex-col items-center justify-center w-full h-full">
                                                            <% if (isLiburColumn) { %>
                                                                <span class="text-red-300 dark:text-red-700 text-xl select-none" title="Minggu ini LIBUR ronda">🚫</span>
                                                            <% } else { %>
                                                                <span 
                                                                    id="cell-<%= row.info.id %>-<%= d %>"
                                                                    data-schedule-id="<%= cell ? cell.id : '' %>"
                                                                    data-warga-id="<%= row.info.id %>"
                                                                    data-date-value="<%= d %>"
                                                                    data-status="<%= (cell && cell.status) ? cell.status : 'scheduled' %>"
                                                                    data-nama="<%= row.info.nama %>"
                                                                    data-date="<%= moment(d).format('DD MMM YYYY') %>"
                                                                    data-keterangan="<%= (cell && cell.keterangan) ? cell.keterangan : '' %>"
                                                                    onclick="openStatusModal(this.dataset.scheduleId, this.dataset.status, this.dataset.nama, this.dataset.date, this.dataset.keterangan, this.dataset.wargaId, this.dataset.dateValue)"
                                                                    class="cursor-pointer hover:bg-gray-200 transition-colors px-2 py-1 rounded text-xs font-bold <%= (cell && cell.status && cell.status !== 'scheduled') ? 'text-indigo-600' : 'text-gray-400' %> uppercase mb-1">
                                                                    <% if (cell && cell.status === 'hadir') { 
                                                                        const isEarly = cell.keterangan && cell.keterangan.includes('Sudah Hadir Lebih Awal');
                                                                    %>
                                                                        <% if (isEarly) { %>
                                                                            <div class="flex items-center justify-center w-7 h-7 rounded-full bg-blue-500/20 text-blue-600 dark:text-blue-400 border border-blue-500/30 shadow-sm transition-transform hover:scale-110" title="Sudah Hadir Lebih Awal">
                                                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                                                                </svg>
                                                                                <span class="absolute -top-1 -right-1 text-[8px] bg-blue-500 text-white rounded-full w-3 h-3 flex items-center justify-center">2</span>
                                                                            </div>
                                                                        <% } else { %>
                                                                            <div class="flex items-center justify-center w-7 h-7 rounded-full bg-green-500/20 text-green-600 dark:text-green-400 border border-green-500/30 shadow-sm transition-transform hover:scale-110" title="Hadir">
                                                                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                                                                </svg>
                                                                            </div>
                                                                        <% } %>
                                                                    <% } else if (cell && cell.status === 'reschedule') { %>
                                                                        <div class="flex items-center justify-center w-7 h-7 rounded-full bg-orange-500/20 text-orange-600 dark:text-orange-400 border border-orange-500/30 shadow-sm transition-transform hover:scale-110" title="Reschedule">
                                                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                                                                            </svg>
                                                                        </div>
                                                                    <% } else if (cell && cell.status === 'alpa') { %>
                                                                        <div class="flex items-center justify-center w-7 h-7 rounded-full bg-red-500/20 text-red-600 dark:text-red-400 border border-red-500/30 shadow-sm" title="Alpa">
                                                                            <span class="text-[10px] font-black">A</span>
                                                                        </div>
                                                                    <% } else if (cell && cell.status === 'izin') { %>
                                                                        <div class="flex items-center justify-center w-7 h-7 rounded-full bg-blue-500/20 text-blue-600 dark:text-blue-400 border border-blue-500/30 shadow-sm" title="Izin">
                                                                            <span class="text-[10px] font-black">I</span>
                                                                        </div>
                                                                    <% } else if (cell && cell.status === 'scheduled') { %>
                                                                        <div class="flex items-center justify-center w-7 h-7 rounded-full bg-indigo-500/10 text-indigo-500 dark:bg-indigo-400/20 dark:text-indigo-400 border border-indigo-200 dark:border-indigo-800" title="Scheduled">
                                                                            <div class="w-1.5 h-1.5 rounded-full bg-current"></div>
                                                                        </div>
                                                                    <% } else { %>
                                                                        <span class="text-gray-400 text-xs font-bold uppercase">-</span>
                                                                    <% } %>
                                                                </span>

                                                                <% if (cell && cell.denda > 0) { %>
                                                                    <% if (cell.status_bayar === 'paid') { %>
                                                                        <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold bg-blue-100 text-blue-700 border border-blue-200 mt-1 cursor-default" title="Lunas">
                                                                            <svg class="w-3 h-3 mr-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                                                            Denda Sudah Lunas
                                                                        </span>
                                                                    <% } else if (cell.status_bayar === 'pending') { %>
                                                                        <% if(user.role === 'admin' || user.role === 'bendahara' || user.role === 'ketua') { %>
                                                                            <span onclick="event.stopPropagation(); openVerifyFineModal('<%= cell.id %>', '<%= cell.bukti_bayar %>')"
