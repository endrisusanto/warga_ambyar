        <script src="/js/html2canvas.min.js"></script>
        <script>
            function exportToImage() {
                const tableContainer = document.querySelector('.overflow-x-auto');
                const btn = document.querySelector('button[onclick="exportToImage()"]');
                const originalText = btn.innerHTML;
                
                btn.innerHTML = 'Scan...';
                
                html2canvas(tableContainer, {
                    scale: 2,
                    backgroundColor: '#ffffff', // Force white background
                    onclone: (clonedDoc) => {
                        const table = clonedDoc.querySelector('table');
                        const thead = table.querySelector('thead');
                        const ths = table.querySelectorAll('th');
                        const tds = table.querySelectorAll('td');
                        
                        // Force Plain Styling
                        table.style.fontFamily = 'Arial, sans-serif';
                        table.style.borderCollapse = 'collapse';
                        table.style.border = '1px solid black';
                        
                        // Reset Heading Colors
                        if(thead) {
                            thead.style.background = '#f0f0f0';
                            thead.className = ''; // Remove dark mode classes
                        }

                        ths.forEach(th => {
                            th.style.border = '1px solid black';
                            th.style.background = '#ffffff';
                            th.style.color = '#000000';
                            th.style.fontWeight = 'bold';
                            th.className = 'px-2 py-1 text-center'; // Reset classes
                        });

                        tds.forEach(td => {
                            td.style.border = '1px solid black';
                            td.style.background = '#ffffff';
                            td.style.color = '#000000';
                            td.className = 'px-2 py-1 text-center'; // Reset classes
                            
                            // Keep specific text clean
                            // Replace badges with text if needed? 
                            // Current UI has badges. User said "plain". 
                            // Let's keep content but force colors.
                            
                            // Check for badges and force them to look plain or keep as color?
                            // "plain border hitam kolom putih" implies the structure.
                            // Let's strictly force black text.
                            const badges = td.querySelectorAll('span, div');
                            badges.forEach(b => {
                                // If badge has background, keep it? or flatten?
                                // "tanpa styling" usually means remove colorful badges.
                                // Let's try to keep text readable.
                                b.style.color = '#000000';
                                // Optional: Remove bg colors from badges
                                // b.style.backgroundColor = 'transparent';
                            });
                        });
                    }
                }).then(canvas => {
                    const link = document.createElement('a');
                    link.download = 'Control_Ronda_<%= year %>_' + new Date().getTime() + '.png';
                    link.href = canvas.toDataURL('image/png');
                    link.click();
                    btn.innerHTML = originalText;
                }).catch(err => {
                    console.error(err);
                    alert('Gagal export image');
                    btn.innerHTML = originalText;
                });
            }

            function exportToCSV() {
                const table = document.querySelector('table');
                let csv = [];
                
                // Header
                const headerRow = table.querySelector('thead tr');
                const headers = [];
                headerRow.querySelectorAll('th').forEach(th => {
                    headers.push('"' + th.innerText.trim() + '"');
                });
                csv.push(headers.join(','));
                
                // Rows
                const rows = table.querySelectorAll('tbody tr');
                rows.forEach(row => {
                    const cols = [];
                    row.querySelectorAll('td').forEach(td => {
                        cols.push('"' + td.innerText.replace(/\n/g, ' ').trim() + '"');
                    });
                    csv.push(cols.join(','));
                });
                
                const csvFile = new Blob([csv.join('\n')], {type: "text/csv"});
                const downloadLink = document.createElement("a");
                downloadLink.download = "Control_Ronda_<%= year %>.csv";
                downloadLink.href = window.URL.createObjectURL(csvFile);
                downloadLink.style.display = "none";
                document.body.appendChild(downloadLink);
                downloadLink.click();
                document.body.removeChild(downloadLink);
            }
        </script>
