                                        <td class="hidden lg:table-cell px-1 py-4 whitespace-nowrap text-center text-sm bg-blue-100 bg-blue-medium lg:sticky lg:right-[180px] z-10 w-[90px] min-w-[90px] max-w-[90px]">
                                            <span class="font-bold text-[10px] sm:text-sm text-blue-600 dark:text-blue-400">
