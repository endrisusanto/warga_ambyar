                                                                            </span>
                                                                        <% } %>
                                                                    <% } else { %>
                                                                        <span onclick="event.stopPropagation(); openQrisPayModal('<%= cell.id %>', '<%= cell.denda %>', '<%= row.info.nama %>')" 
