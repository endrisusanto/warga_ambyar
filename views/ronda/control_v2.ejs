        <!-- Status Modal -->
        <div id="statusModal" class="fixed inset-0 bg-black/60 hidden overflow-y-auto h-full w-full z-50 backdrop-blur-sm">
            <div class="relative top-20 mx-auto p-6 glass-card w-full max-w-md shadow-2xl">
                <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-6 flex items-center gap-2">
                    <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                    </svg>
                    Ubah Status Absensi
                </h3>
                <form id="statusForm" action="/ronda/update-status" method="POST">
                    <input type="hidden" id="statusScheduleId" name="id">
                    <input type="hidden" id="statusWargaId" name="warga_id">
                    <input type="hidden" id="statusDate" name="date">
                    <input type="hidden" name="redirectUrl" value="/ronda/control?year=<%= year %>">
                    
                    <div class="mb-4">
                        <label class="block text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">Nama Warga</label>
                        <div id="statusWargaName" class="text-base font-bold text-gray-900 dark:text-gray-100"></div>
                        <div id="statusDateLabel" class="text-xs text-indigo-500 font-medium"></div>
                    </div>

                    <div class="mb-5">
                        <label class="block text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2">Status Kehadiran</label>
                        <select name="status" id="statusSelect" class="glass-input block w-full rounded-xl p-3 outline-none cursor-pointer text-gray-900 dark:text-gray-100 bg-white dark:bg-gray-800 focus:ring-2 focus:ring-indigo-500 border border-gray-200 dark:border-gray-700 dark:[color-scheme:dark]">
                            <option value="scheduled">Scheduled (Reset)</option>
                            <option value="hadir">✅ Hadir</option>
                            <option value="alpa">Alpa (Denda)</option>
                            <option value="reschedule_next">➡️ Reschedule (Minggu Depan)</option>
                            <option value="reschedule_prev">⬅️ Maju Jadwal (Minggu Lalu)</option>
                        </select>
                    </div>
                    
                    <div class="mb-6">
                        <label class="block text-xs font-bold text-gray-600 dark:text-gray-400 uppercase tracking-wider mb-2">Keterangan</label>
                        <textarea name="keterangan" id="statusKeterangan" rows="3" placeholder="Tambahkan catatan jika diperlukan..." class="glass-input block w-full rounded-xl p-3 outline-none resize-none text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-indigo-500"></textarea>
                    </div>

                    <div class="flex justify-end gap-3 pt-4 border-t border-gray-100 dark:border-white/10">
                        <button type="button" onclick="document.getElementById('statusModal').classList.add('hidden')" class="px-5 py-2.5 rounded-xl text-sm font-bold text-gray-600 dark:text-gray-400 hover:text-gray-800 hover:bg-gray-100 dark:hover:bg-white/10 transition-colors">Batal</button>
                        <button type="submit" id="submitStatusBtn" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2.5 rounded-xl font-bold shadow-lg transition-all transform hover:scale-[1.02] flex items-center gap-2">
                            <span>Simpan Perubahan</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <script>
            let sortDirection = 1; // 1 asc, -1 desc
            let lastColIndex = -1; // Reset to -1 to ensure first click or auto-sort triggers ASC

            document.addEventListener('DOMContentLoaded', () => {
                // Force sort by Warga (Tim Ronda) ASC on load
                sortTable(0, 'string');
            });

            function sortTable(colIndexRelative, type) {
                const table = document.querySelector('table');
                const tbody = table.querySelector('tbody');
                // All rows except the last one (Grand Total)
                const rows = Array.from(tbody.querySelectorAll('tr')).slice(0, -1);
                // The Grand Total row (to insert before)
                const grandTotalRow = tbody.querySelector('tr:last-child');
                const headerRow = table.querySelector('thead tr');
                
                // Calculate absolute column index
                // For negative index, it counts from the end
                let colIndex = colIndexRelative;
                if (colIndexRelative < 0) {
                    // Total columns in the header row
                    const totalCols = headerRow.children.length;
                    colIndex = totalCols + colIndexRelative;
                }

                // Toggle logic
                if (lastColIndex === colIndex) {
                    sortDirection *= -1;
                } else {
                    sortDirection = 1;
                    lastColIndex = colIndex;
                }

                // Reset all icons
                document.querySelectorAll('.sort-icon').forEach(icon => {
                    icon.textContent = '⇵';
                    icon.classList.remove('text-gray-900', 'dark:text-white', 'text-gray-400');
                    icon.classList.add('text-gray-400');
                });
                
                // Update active icon
                const targetHeader = headerRow.children[colIndex];
                if(targetHeader) {
                    const icon = targetHeader.querySelector('.sort-icon');
                    if(icon) {
                        icon.textContent = sortDirection === 1 ? '↑' : '↓';
                        icon.classList.remove('text-gray-400');
                        icon.classList.add('text-gray-900', 'dark:text-white');
                    }
                }

                // Sort rows
                rows.sort((a, b) => {
                    const cellA = a.children[colIndex];
                    const cellB = b.children[colIndex];
                    
                    if (!cellA || !cellB) return 0;

                    const valA = getCellValue(cellA, type);
                    const valB = getCellValue(cellB, type);
                    
                    if (valA < valB) return -1 * sortDirection;
                    if (valA > valB) return 1 * sortDirection;
                    return 0;
                });

                // Re-append sorted rows
                rows.forEach(row => tbody.insertBefore(row, grandTotalRow));
            }

            // AJAX Status Update
            document.getElementById('statusForm').addEventListener('submit', async function(e) {
                e.preventDefault();
                const btn = document.getElementById('submitStatusBtn');
                const originalText = btn.innerHTML;
                btn.innerHTML = '<svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Saving...';
                btn.disabled = true;

                const formData = new FormData(this);
                const data = Object.fromEntries(formData.entries());

                try {
                    const response = await fetch(this.action, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'Accept': 'application/json'
                        }
                    });

                    const result = await response.json();
                    if (result.success) {
                        // Update UI for current cell
                        const cellId = `cell-${result.warga_id}-${data.date}`;
                        const cellElement = document.getElementById(cellId);
                        if (cellElement) {
                            updateCellUI(cellElement, result.status, result.id, data.keterangan);
                        }

                        // If reschedule, update target cell
                        if (result.status === 'reschedule' && result.nextDate) {
                            const nextCellId = `cell-${result.warga_id}-${result.nextDate}`;
                            const nextCellElement = document.getElementById(nextCellId);
                            if (nextCellElement) {
                                // For the target week, it becomes 'scheduled'
                                updateCellUI(nextCellElement, 'scheduled', '', '');
                            }
                        }

                        document.getElementById('statusModal').classList.add('hidden');
                        // Show success toast (optional, using simple alert for now)
                        console.log('Update success');
                    } else {
                        alert('Gagal update: ' + (result.message || 'Unknown error'));
                    }
                } catch (err) {
                    console.error('Error:', err);
                    alert('Terjadi kesalahan jaringan');
                } finally {
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            });

            function updateCellUI(el, status, newId, newKet) {
                // Update data attributes
                el.dataset.status = status;
                if (newId) el.dataset.scheduleId = newId;
                el.dataset.keterangan = newKet;

                // Update content based on status
                let content = '';
                if (status === 'hadir') {
                    if (newKet && newKet.includes('Sudah Hadir Lebih Awal')) {
                        content = `<div class="flex items-center justify-center w-7 h-7 rounded-full bg-blue-500/20 text-blue-600 dark:text-blue-400 border border-blue-500/30 shadow-sm transition-transform hover:scale-110" title="Sudah Hadir Lebih Awal">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                    <span class="absolute -top-1 -right-1 text-[8px] bg-blue-500 text-white rounded-full w-3 h-3 flex items-center justify-center">2</span>
                                  </div>`;
                    } else {
                        content = `<div class="flex items-center justify-center w-7 h-7 rounded-full bg-green-500/20 text-green-600 dark:text-green-400 border border-green-500/30 shadow-sm transition-transform hover:scale-110" title="Hadir"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg></div>`;
                    }
                } else if (status === 'reschedule_prev' || (status === 'reschedule' && newKet && newKet.includes('[Maju Jadwal]'))) {
                    content = `<div class="flex items-center justify-center w-7 h-7 rounded-full bg-green-500/20 text-green-600 dark:text-green-400 border border-green-500/30 shadow-sm transition-transform hover:scale-110" title="Maju Jadwal / Sudah Hadir">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
                                <span class="absolute -top-1 -right-1 text-[8px] bg-green-500 text-white rounded-full w-3 h-3 flex items-center justify-center"><svg class="w-2 h-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7"></path></svg></span>
                              </div>`;
                } else if (status === 'reschedule' || status === 'reschedule_next') {
                    content = `<div class="flex items-center justify-center w-7 h-7 rounded-full bg-orange-500/20 text-orange-600 dark:text-orange-400 border border-orange-500/30 shadow-sm transition-transform hover:scale-110" title="Reschedule"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path></svg></div>`;
                } else if (status === 'alpa') {
                    content = `<div class="flex items-center justify-center w-7 h-7 rounded-full bg-red-500/20 text-red-600 dark:text-red-400 border border-red-500/30 shadow-sm" title="Alpa"><span class="text-[10px] font-black">A</span></div>`;
                } else if (status === 'izin') {
                    content = `<div class="flex items-center justify-center w-7 h-7 rounded-full bg-blue-500/20 text-blue-600 dark:text-blue-400 border border-blue-500/30 shadow-sm" title="Izin"><span class="text-[10px] font-black">I</span></div>`;
                } else if (status === 'scheduled') {
                    content = `<div class="flex items-center justify-center w-7 h-7 rounded-full bg-indigo-500/10 text-indigo-500 dark:bg-indigo-400/20 dark:text-indigo-400 border border-indigo-200 dark:border-indigo-800" title="Scheduled"><div class="w-1.5 h-1.5 rounded-full bg-current"></div></div>`;
                } else {
                    content = `<span class="text-gray-400 text-xs font-bold uppercase">-</span>`;
                }
                el.innerHTML = content;
                
                // Update text color of span
                if (status !== 'scheduled' && status !== '') {
                    el.classList.remove('text-gray-400');
                    el.classList.add('text-indigo-600');
                } else {
                    el.classList.remove('text-indigo-600');
                    el.classList.add('text-gray-400');
                }
            }

            function getCellValue(cell, type) {
                // Priority: Custom sort attribute for Tim Ronda (Warga column)
                if (cell.hasAttribute('data-tim')) {
                    const val = cell.getAttribute('data-tim');
                    // Put empty values at the end when ascending ('z')
                    return val ? val.toLowerCase() : 'z';
                }

                // For attendance cells, look for data-status on the inner span
                const statusSpan = cell.querySelector('[data-status]');
                if (statusSpan) {
                    return statusSpan.getAttribute('data-status').toLowerCase();
                }

                let text = cell.innerText.trim(); 
                
                if (type === 'number') {
                    // Remove 'Rp', '.', ' ', 'x', '-'
                    const cleanText = text.replace(/[^0-9-]/g, ''); 
                    if (!cleanText || cleanText === '-') return 0;
                    return parseInt(cleanText, 10);
                }
                
                // Fallback for other string columns
                return text.toLowerCase();
            }

            function openStatusModal(id, currentStatus, name, date, keterangan, wargaId, dateValue) {
                document.getElementById('statusScheduleId').value = id || '';
                document.getElementById('statusWargaId').value = wargaId || '';
                document.getElementById('statusDate').value = dateValue || '';
                document.getElementById('statusWargaName').textContent = name;
                document.getElementById('statusDateLabel').textContent = date;
                document.getElementById('statusSelect').value = currentStatus && currentStatus !== '' ? currentStatus : 'scheduled';
                document.getElementById('statusKeterangan').value = keterangan || '';
                document.getElementById('statusModal').classList.remove('hidden');
            }

            function openPayFineModal(ids, amount, name) {
                document.getElementById('fineIds').value = ids;
                document.getElementById('fineAmountDisplay').textContent = 'Rp ' + parseInt(amount).toLocaleString('id-ID');
                document.getElementById('fineWargaName').textContent = name;
                document.getElementById('payFineModal').classList.remove('hidden');
            }
            
            async function openQrisPayModal(id, denda, name) {
                document.getElementById('qrisFineId').value = id;
                document.getElementById('qrisAmountDisplay').innerText = 'Rp ' + parseInt(denda).toLocaleString('id-ID');
                document.getElementById('qrisModal').classList.remove('hidden');

                // Reset Canvas
                const canvas = document.getElementById('qrisCanvas');
                const context = canvas.getContext('2d');
                context.clearRect(0, 0, canvas.width, canvas.height);
                
                // Show Loading
                context.font = "14px Arial";
                context.fillText("Loading QRIS...", 50, 50);

                try {
                    // Simple merchant name format: DENDA RONDA [NAME]
                    const firstName = name.split(' ')[0].substring(0, 15).toUpperCase();
                    let merchantName = `DENDA RONDA ${firstName}`.toUpperCase();
                    if(merchantName.length > 25) merchantName = merchantName.substring(0, 25);
                    
                    console.log('Generating QRIS for:', merchantName, 'Amount:', parseInt(denda));

                    // Fetch generated QRIS from backend (same endpoint as iuran payment)
                    const response = await fetch('/iuran/generate-qris', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ amount: parseInt(denda), merchantName: merchantName })
                    });
                    
                    const data = await response.json();
                    
                    if (data.success && data.qr_string) {
                        // Generate QR Code with proper error handling
                        QRCode.toCanvas(canvas, data.qr_string, { 
                            width: 200, 
                            margin: 2,
                            errorCorrectionLevel: 'M'
                        }, function (error) {
                            if (error) {
                                console.error('QR Code generation error:', error);
                                context.clearRect(0, 0, canvas.width, canvas.height);
                                context.font = "12px Arial";
                                context.fillText("Error generating QR", 30, 50);
                            }
                        });
                    } else {
                        context.clearRect(0, 0, canvas.width, canvas.height);
                        context.font = "12px Arial";
                        context.fillText("Gagal generate QRIS", 30, 50);
                        alert('Gagal generate QRIS: ' + (data.error || 'Unknown error'));
                    }

                } catch (error) {
                    console.error('Error preparing QRIS:', error);
                    context.clearRect(0, 0, canvas.width, canvas.height);
                    context.font = "12px Arial";
                    context.fillText("Network error", 50, 50);
                    alert('Error preparing QRIS: ' + error.message);
                }
            }

            // ── Week Menu Dropdown ────────────────────────────────────────────
            let _activeWeekDate = null;

            function showWeekMenu(event, date) {
                event.stopPropagation();
                _activeWeekDate = date;

                const menu = document.getElementById('weekActionMenu');
                const label = document.getElementById('weekMenuDateLabel');

                // Format tanggal untuk label
                const d = new Date(date + 'T00:00:00');
                const options = { day: 'numeric', month: 'short', year: 'numeric' };
                label.textContent = 'Tgl ' + d.toLocaleDateString('id-ID', options);

                // Posisikan dropdown di dekat kursor / th
                const rect = event.currentTarget.getBoundingClientRect();
                const scrollY = window.scrollY || window.pageYOffset;
                const scrollX = window.scrollX || window.pageXOffset;

                menu.style.top = (rect.bottom + scrollY + 4) + 'px';
                let left = rect.left + scrollX;
                // Pastikan tidak overflow ke kanan
                if (left + 200 > window.innerWidth) left = window.innerWidth - 210;
                menu.style.left = left + 'px';

                menu.classList.remove('hidden');
                menu.classList.add('flex');
            }

            function closeWeekMenu() {
                const menu = document.getElementById('weekActionMenu');
                menu.classList.add('hidden');
                menu.classList.remove('flex');
                _activeWeekDate = null;
            }

            async function doSkipWeek() {
                if (!_activeWeekDate) return;
                const date = _activeWeekDate;
                closeWeekMenu();
                if (!confirm('Liburkan ronda tanggal ' + date + '?\n\nSemua jadwal pada dan SETELAH tanggal ini akan bergeser maju 1 minggu secara otomatis.')) return;
                await callWeekAction('/ronda/skip-week', date, 'Jadwal berhasil diliburkan dan digeser 1 minggu.');
            }

            async function doResetWeek() {
                if (!_activeWeekDate) return;
                const date = _activeWeekDate;
                closeWeekMenu();
                if (!confirm('Reset / kembalikan jadwal tanggal ' + date + '?\n\nSemua jadwal pada dan SETELAH tanggal ini akan digeser mundur 1 minggu (kebalikan dari Liburkan).')) return;
                await callWeekAction('/ronda/reset-week', date, 'Jadwal berhasil di-reset / digeser mundur 1 minggu.');
            }

            async function callWeekAction(url, date, successMsg) {
                try {
                    const btn = document.getElementById('weekMenuLoading');
                    if (btn) btn.classList.remove('hidden');
                    const response = await fetch(url, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ date })
                    });
                    const data = await response.json();
                    if (data.success) {
                        alert(successMsg);
                        window.location.reload();
                    } else {
                        alert('Gagal: ' + data.error);
                    }
                } catch (err) {
                    alert('Terjadi kesalahan jaringan.');
                    console.error(err);
                }
            }

            // Tutup dropdown saat klik di luar
            document.addEventListener('click', function(e) {
                const menu = document.getElementById('weekActionMenu');
                if (menu && !menu.contains(e.target)) {
                    closeWeekMenu();
                }
            });
        </script>

