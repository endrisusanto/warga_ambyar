                                                <%= sudahBayar > 0 ? 'Rp ' + sudahBayar.toLocaleString('id-ID') : '-' %>
                                            </span>
                                        </td>
                                        <td class="hidden lg:table-cell px-1 py-4 whitespace-nowrap text-center text-sm bg-red-50 bg-red-soft lg:sticky lg:right-[90px] z-10 w-[90px] min-w-[90px] max-w-[90px]">
