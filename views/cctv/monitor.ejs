                { id: 'CT-02', name: 'RSUD Kab Bekasi (Cibitung)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-02/index.m3u8' },
                { id: 'CT-03', name: 'Stasiun Lemah Abang', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-03/index.m3u8' },
                { id: 'CT-04', name: 'U-Turn Besar Perum BCL (Pintu Kereta Perum Graha Asri)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-04/index.m3u8' },
                { id: 'CT-05', name: 'Pintu Kereta Citarik (Michelin)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-05/index.m3u8' },
                { id: 'CT-06', name: 'KPU Kab Bekasi', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-06/index.m3u8' },
                { id: 'CT-07', name: 'RS DKH Kedungwaringin (Hino Showroom)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-07/index.m3u8' },
                { id: 'CT-08', name: 'Jalan Lingkar Karawang (Hadap Cikarang)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-08/index.m3u8' },
                { id: 'CT-09', name: 'Pintu TOL Klari', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-09/index.m3u8' }
            ];

            // Initialize HLS Player
            function initHLS(video, url) {
                if (Hls.isSupported()) {
                    const hls = new Hls({
                        enableWorker: true,
                        lowLatencyMode: true,
                        backBufferLength: 90
                    });
                    hls.loadSource(url);
                    hls.attachMedia(video);
                    return hls;
                } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                    video.src = url;
                    return null;
                }
            }

            // Create CCTV Cards
            let publicCamerasLoaded = false;
            
            function initPublicCameras() {
                const grid = document.getElementById('cctvGrid');
                cameras.forEach(camera => {
                    const card = document.createElement('div');
                    card.className = 'cctv-card';
                    card.innerHTML = `
                <div class="cctv-video-wrapper">
                    <video class="cctv-video" autoplay muted playsinline></video>
                    <div class="cctv-loading">
                        <div class="loading-spinner"></div>
                        <div class="text-xs text-white font-bold drop-shadow-md mt-2" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">Connecting...</div>
                    </div>
                    <div class="cctv-overlay">
                        <div class="live-badge">● LIVE</div>
                        <div class="cctv-info">
                            <div class="text-xs text-white font-bold drop-shadow-md" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${camera.id}</div>
                            <div class="text-sm text-white font-bold drop-shadow-md" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${camera.name}</div>
                        </div>
                        <button class="expand-button" onclick="openModal('${camera.id}')">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            `;

                    const video = card.querySelector('.cctv-video');
                    const loading = card.querySelector('.cctv-loading');
                    video.muted = true;
                    video.defaultMuted = true;

                    // Initialize HLS
                    const hls = initHLS(video, camera.url);

                    // Hide loading when video starts
                    video.addEventListener('loadeddata', () => {
                        loading.style.display = 'none';
                    });

                    grid.appendChild(card);
                });
            }

            // Frigate Camera Data
            const go2rtcBaseUrl = 'https://camera.ambyar.biz.id';
            // ponytail: aligned with go2rtc active streams, removed disabled and duplicate snapshot/mse entries (YAGNI)
            const frigateCameras = [
                { id: 'CCTV-GANG-1', name: 'Ujung Selatan', src: 'cctv_gang_ambyar' },
                { id: 'KALULA-HOME', name: 'CCTV Kalula Home', src: 'cctv_kalula' },
                { id: 'CCTV-GANG-2', name: 'Ujung Utara & Tengah', src: 'security_camera', ratio: '800/896' }
            ];

            function frameUrl(src) {
                return `${go2rtcBaseUrl}/api/frame.jpeg?src=${encodeURIComponent(src)}&_=${Date.now()}`;
            }

            function startSnapshotRefresh(img, src, intervalMs = 5000) {
                const refresh = () => {
                    const tempImg = new Image();
                    tempImg.onload = () => {
                        img.src = tempImg.src;
                    };
                    tempImg.src = frameUrl(src);
                };
                
                if (!img.getAttribute('src') || img.getAttribute('src') === '') {
                    img.src = frameUrl(src);
                } else {
                    refresh();
                }
                
                return window.setInterval(refresh, intervalMs);
            }

            function adminHideButton(camera) {
                if (!isAdmin) return '';
                const hidden = hiddenCameras.has(camera.id);
                const title = hidden ? 'Tampilkan kamera' : 'Sembunyikan kamera';
                const iconPath = hidden
                    ? 'M3 3l18 18M10.584 10.587A2 2 0 0012 14a2 2 0 001.412-.584M9.88 4.24A9.85 9.85 0 0112 4c4.478 0 8.268 2.943 9.542 7a10.515 10.515 0 01-3.07 4.568M6.11 6.11A10.506 10.506 0 002.458 11C3.732 15.057 7.523 18 12 18c1.347 0 2.633-.268 3.807-.754'
                    : 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z';

                return `
                    <button class="hide-camera-button ${hidden ? 'is-hidden' : ''}" onclick="toggleCameraHidden('${camera.id}', event)" title="${title}" aria-label="${title}">
                        <svg class="w-5 h-5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="${iconPath}"></path>
                        </svg>
                    </button>
                `;
            }

            function hiddenCameraBadge(camera) {
                return isAdmin && hiddenCameras.has(camera.id) ? '<div class="hidden-camera-badge">Hidden</div>' : '';
            }

            // Create Frigate Cards using video-rtc custom element
            function initFrigateCameras() {
                const frigateGrid = document.getElementById('frigateGrid');
                if (!frigateGrid) return;
                frigateGrid.innerHTML = '';
                
                frigateCameras.forEach(camera => {
                    if (!isAdmin && hiddenCameras.has(camera.id)) return;

                    const card = document.createElement('div');
                    card.className = `cctv-card${hiddenCameras.has(camera.id) ? ' camera-hidden' : ''}`;
                    if (camera.ratio) {
                        card.style.aspectRatio = camera.ratio;
                    }
                    
                    card.innerHTML = `
                <div class="cctv-video-wrapper">
                    <video-rtc class="cctv-video live-player" data-camera-id="${camera.id}" style="width: 100%; height: 100%; display: none;" autoplay muted playsinline></video-rtc>
                    <img class="cctv-video snapshot-img" alt="${camera.name}" data-camera-id="${camera.id}" style="display: block; object-fit: cover; width: 100%; height: 100%;">
                    ${hiddenCameraBadge(camera)}
                    <div class="cctv-loading">
                        <div class="loading-spinner"></div>
                        <div class="text-xs text-white font-bold drop-shadow-md mt-2" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">Connecting...</div>
                    </div>
                    <div class="cctv-overlay">
                        <div class="live-badge" style="display: none;">● LIVE</div>
                        <div class="cctv-info">
                            <div class="text-xs text-white font-bold drop-shadow-md" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${camera.id}</div>
                            <div class="text-sm text-white font-bold drop-shadow-md" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${camera.name}</div>
                        </div>
                        <button class="expand-button" onclick="openFrigateModal('${camera.id}')">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path>
                            </svg>
                        </button>
                        <!-- Mode Toggle Button (Live/Snapshot) -->
                        ${camera.id !== 'CCTV-GANG-2' ? `
                        <button class="mode-toggle-btn absolute bottom-3 right-3 px-3 py-1 bg-white/10 hover:bg-white/20 border border-white/20 backdrop-blur-md text-white text-xs font-semibold rounded-lg flex items-center gap-1.5 transition-all duration-200" onclick="togglePlayMode('${camera.id}', event)">
                            <span class="mode-indicator w-2 h-2 rounded-full bg-yellow-500"></span>
                            <span class="mode-label">Snapshot</span>
                        </button>
                        ` : `
                        <div class="absolute bottom-3 right-3 px-3 py-1 bg-white/10 border border-white/20 backdrop-blur-md text-white text-xs font-semibold rounded-lg flex items-center gap-1.5 opacity-90 cursor-default" title="Kamera ini hanya mendukung mode Snapshot">
                            <span class="w-2 h-2 rounded-full bg-yellow-500"></span>
                            <span>Snapshot</span>
                        </div>
                        `}
                        ${adminHideButton(camera)}
                    </div>
                </div>
            `;
                    frigateGrid.appendChild(card);

                    // Initialize video-rtc player properties (but don't load stream URL yet to save bandwidth)
                    const player = card.querySelector('video-rtc.live-player');
                    player.mode = 'mse';
                    
                    // Hide loading spinner when stream data starts playing
                    const loading = card.querySelector('.cctv-loading');
                    player.addEventListener('loadeddata', () => {
                        loading.style.display = 'none';
                    }, true);

                    const video = player.querySelector('video');
                    if (video) {
                        video.controls = false;
                    }

                    // Start periodic snapshot refresh
                    const img = card.querySelector('img.snapshot-img');
                    img.src = frameUrl(camera.src);
                    img.onload = () => { loading.style.display = 'none'; };
                    img.onerror = () => { loading.style.display = 'none'; };

                    snapshotTimers[camera.id] = startSnapshotRefresh(img, camera.src, 5000);
                });
            }

            // Load and register video-rtc custom element, then initialize cards
            import('/js/video-rtc.js')
                .then(module => {
                    if (!customElements.get('video-rtc')) {
                        customElements.define('video-rtc', module.VideoRTC);
                    }
                    initFrigateCameras();
                })
                .catch(err => console.error('Failed to load video-rtc.js:', err));

            // Keep track of active timers for snapshots per camera card
            const snapshotTimers = {};

            // ponytail: toggles stream element on and off to save bandwidth / CPU when requested (YAGNI / minimal code)
            function togglePlayMode(cameraId, event) {
                if (event) event.stopPropagation();
                const card = document.querySelector(`.cctv-card [data-camera-id="${cameraId}"]`)?.closest('.cctv-card');
                if (!card) return;

                const player = card.querySelector('video-rtc.live-player');
                const img = card.querySelector('img.snapshot-img');
                const loading = card.querySelector('.cctv-loading');
                const btn = card.querySelector('.mode-toggle-btn');
                const indicator = btn.querySelector('.mode-indicator');
                const label = btn.querySelector('.mode-label');
                const liveBadge = card.querySelector('.live-badge');
                const camera = frigateCameras.find(c => c.id === cameraId);
                if (!camera) return;

                if (player.style.display !== 'none') {
                    // Switch to Snapshot mode
                    player.style.display = 'none';
                    player.ondisconnect(); // stop streaming
                    img.style.display = 'block';
                    if (liveBadge) liveBadge.style.display = 'none';
                    
                    // Start periodic snapshot refresh
                    loading.style.display = 'block';
                    img.src = frameUrl(camera.src);
                    img.onload = () => { loading.style.display = 'none'; };
                    img.onerror = () => { loading.style.display = 'none'; };

                    snapshotTimers[cameraId] = startSnapshotRefresh(img, camera.src, 5000);

                    // Update button UI
                    indicator.className = 'mode-indicator w-2 h-2 rounded-full bg-yellow-500';
                    label.textContent = 'Snapshot';
                } else {
                    // Switch to Live (MSE) mode
                    if (snapshotTimers[cameraId]) {
                        clearInterval(snapshotTimers[cameraId]);
                        delete snapshotTimers[cameraId];
                    }
                    img.style.display = 'none';
                    img.src = '';
                    
                    player.style.display = 'block';
                    loading.style.display = 'block';
                    if (liveBadge) liveBadge.style.display = 'block';
                    player.src = `${go2rtcBaseUrl}/api/ws?src=${encodeURIComponent(camera.src)}`;

                    // Update button UI
                    indicator.className = 'mode-indicator w-2 h-2 rounded-full bg-green-500';
                    label.textContent = 'Live';
                }
            }

            async function toggleCameraHidden(cameraId, event) {
                event.stopPropagation();
                const shouldHide = !hiddenCameras.has(cameraId);
                const actionText = shouldHide ? 'sembunyikan' : 'tampilkan kembali';

                if (!confirm(`Yakin ingin ${actionText} kamera ini?`)) return;

                try {
                    const response = await fetch('/cctv/hide-camera', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({
                            camera_id: cameraId,
                            hidden: shouldHide
                        })
                    });
                    const result = await response.json();

                    if (!response.ok || !result.success) {
                        throw new Error(result.message || 'Gagal menyimpan status kamera.');
                    }

                    window.location.reload();
                } catch (error) {
                    alert(error.message || 'Gagal menyimpan status kamera.');
                }
            }

            // Modal Functions
            let modalHls = null;
            let modalSnapshotTimer = null;

            function openModal(cameraId) {
                const camera = cameras.find(c => c.id === cameraId);
                if (!camera) return;

                const modal = document.getElementById('modalOverlay');
                const video = document.getElementById('modalVideo');
                const iframe = document.getElementById('modalIframe');
                const image = document.getElementById('modalImage');

                document.getElementById('modalCameraName').textContent = camera.name;
                document.getElementById('modalCameraId').textContent = camera.id;

                video.style.display = 'block';
                iframe.style.display = 'none';
                image.style.display = 'none';
                video.muted = true;
                video.defaultMuted = true;
                iframe.src = '';
                image.src = '';

                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';

                if (modalSnapshotTimer) {
                    clearInterval(modalSnapshotTimer);
                    modalSnapshotTimer = null;
                }

                if (modalHls) {
                    modalHls.destroy();
                }

                modalHls = initHLS(video, camera.url);
            }

            // ponytail: simplified modal to always show the live MSE stream for maximum detail, eliminating WebRTC branching (YAGNI)
            function openFrigateModal(cameraId) {
                const camera = frigateCameras.find(c => c.id === cameraId);
                if (!camera) return;

                const modal = document.getElementById('modalOverlay');
                const video = document.getElementById('modalVideo');
                const iframe = document.getElementById('modalIframe');
                const image = document.getElementById('modalImage');
                const webrtc = document.getElementById('modalWebrtc');
                const videoContainer = document.querySelector('.modal-video-container');
                const modalContent = document.querySelector('.modal-content');

                document.getElementById('modalCameraName').textContent = camera.name;
                document.getElementById('modalCameraId').textContent = camera.id;
                
                if (videoContainer && modalContent) {
                    videoContainer.style.aspectRatio = camera.ratio || '16/9';
                    if (camera.ratio && camera.ratio !== '16/9') {
                        const parts = camera.ratio.split('/');
                        let ratioVal = 1;
                        if (parts.length === 2) {
                            ratioVal = parseFloat(parts[0]) / parseFloat(parts[1]);
                        }
                        modalContent.style.maxWidth = `min(1200px, calc(85vh * ${ratioVal}))`;
                    } else {
                        modalContent.style.maxWidth = '1200px';
                    }
                }

                image.style.display = 'none';
                video.style.display = 'none';
                iframe.style.display = 'none';
                if (webrtc) {
                    webrtc.style.display = 'block';
                    webrtc.mode = 'mse';
                    webrtc.src = `${go2rtcBaseUrl}/api/ws?src=${encodeURIComponent(camera.src)}`;
                }

                if (modalHls) {
                    modalHls.destroy();
                    modalHls = null;
                }
                if (modalSnapshotTimer) {
                    clearInterval(modalSnapshotTimer);
                    modalSnapshotTimer = null;
                }

                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }

            function closeModal() {
                const modal = document.getElementById('modalOverlay');
                const video = document.getElementById('modalVideo');
                const iframe = document.getElementById('modalIframe');
                const image = document.getElementById('modalImage');
                const webrtc = document.getElementById('modalWebrtc');

                modal.classList.add('hidden');
                document.body.style.overflow = '';

                if (modalSnapshotTimer) {
                    clearInterval(modalSnapshotTimer);
                    modalSnapshotTimer = null;
                }
                if (modalHls) {
                    modalHls.destroy();
                    modalHls = null;
                }
                video.pause();
                video.removeAttribute('src');
                video.load();
                image.removeAttribute('src');
                image.style.display = 'none';
                
                iframe.src = '';
                if (webrtc) {
                    webrtc.ondisconnect();
                    webrtc.style.display = 'none';
                }
            }

            // Close modal on ESC key
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') closeModal();
            });

            // Tab Switching Logic
            function switchTab(tab) {
                const tabLaluLintas = document.getElementById('tab-lalu-lintas');
                const tabFrigate = document.getElementById('tab-frigate');
                const contentLaluLintas = document.getElementById('content-lalu-lintas');
                const contentFrigate = document.getElementById('content-frigate');
                const desc = document.getElementById('monitor-desc');
                const sirenButton = document.getElementById('sirenButton');

                const activeTabClass = 'border-indigo-500 text-indigo-400 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors duration-200';
                const inactiveTabClass = 'border-transparent text-gray-400 hover:text-gray-300 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors duration-200';

                if (tab === 'lalu-lintas') {
                    if (!publicCamerasLoaded) {
                        initPublicCameras();
                        publicCamerasLoaded = true;
                    }
                    tabLaluLintas.className = activeTabClass;
                    tabFrigate.className = inactiveTabClass;
                    
                    contentLaluLintas.className = 'block';
                    contentFrigate.className = 'hidden';
                    
                    desc.textContent = 'Live streaming dari 9 titik kamera CCTV di area perjalanan kerja';
                    if (sirenButton) sirenButton.classList.add('hidden');
                } else if (tab === 'frigate') {
                    tabFrigate.className = activeTabClass;
                    tabLaluLintas.className = inactiveTabClass;
                    
                    contentFrigate.className = 'block';
                    contentLaluLintas.className = 'hidden';
                    
                    desc.textContent = 'Sistem monitoring CCTV lokal area gang';
                    if (sirenButton) sirenButton.classList.remove('hidden');
                }
            }

            // Client-side timer trackers
            let alarmCountdownTimer = null;
            let alarmCountdownValue = 0;

            function openAlarmModal() {
                const modal = document.getElementById('alarmModalOverlay');
                if (modal) {
                    modal.classList.remove('hidden');
                    document.body.style.overflow = 'hidden';
                }
            }

            function closeAlarmModal() {
                const modal = document.getElementById('alarmModalOverlay');
                if (modal) {
                    modal.classList.add('hidden');
                    document.body.style.overflow = '';
                }
            }

            function updateDurationLabel(val) {
                const label = document.getElementById('alarmDurationVal');
                if (label) {
                    label.textContent = `${val} Detik`;
                }
            }

            // Close alarm config modal on ESC
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') {
                    closeAlarmModal();
                }
            });

            async function triggerCustomAlarm() {
                const triggerSirenGcc2 = document.getElementById('alarmSirenGcc2Toggle').checked;
                const triggerSiren = document.getElementById('alarmSirenToggle').checked;
                const triggerLight = document.getElementById('alarmLightToggle').checked;
                const duration = parseInt(document.getElementById('alarmDurationSlider').value) || 5;

                const entities = [];
                if (triggerSirenGcc2) entities.push('siren.camera_gcc2_f7f8_siren');
                if (triggerSiren) entities.push('siren.security_camera');
                if (triggerLight) entities.push('light.security_camera_floodlight');

                if (entities.length === 0) {
                    alert('Silakan aktifkan minimal satu entitas alarm.');
                    return;
                }

                if (!confirm(`Konfirmasi untuk mengaktifkan alarm selama ${duration} detik?`)) {
                    return;
                }

                closeAlarmModal();

                try {
                    const response = await fetch('/cctv/siren', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({
                            duration: duration,
                            entities: entities
                        })
                    });
                    const result = await response.json();

                    if (!response.ok || !result.success) {
                        throw new Error(result.message || 'Gagal mengirim perintah alarm.');
                    }

                    // Start Shooter Game border pulse effect
                    startShooterVignetteEffect(duration);

                } catch (error) {
                    alert('Gagal mengaktifkan alarm: ' + error.message);
                }
            }

            function startShooterVignetteEffect(duration) {
                const vignette = document.getElementById('shooter-vignette');
                const display = document.getElementById('alarm-countdown-display');
                const secondsLabel = document.getElementById('alarm-countdown-seconds');

                if (!vignette || !display || !secondsLabel) return;

                // Clear previous timers if any
                if (alarmCountdownTimer) {
                    clearInterval(alarmCountdownTimer);
                }

                alarmCountdownValue = duration;
                secondsLabel.textContent = `${alarmCountdownValue}s`;

                // Show elements
                vignette.classList.add('active');
                display.classList.remove('hidden');

                alarmCountdownTimer = setInterval(() => {
                    alarmCountdownValue--;
                    if (alarmCountdownValue <= 0) {
                        clearInterval(alarmCountdownTimer);
                        alarmCountdownTimer = null;
                        vignette.classList.remove('active');
                        display.classList.add('hidden');
                    } else {
                        secondsLabel.textContent = `${alarmCountdownValue}s`;
                    }
                }, 1000);
            }
        </script>

