<%- include('../partials/head') %>
    <%- include('../partials/navbar') %>

        <style>
            .cctv-card {
                position: relative;
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 12px;
                overflow: hidden;
                transition: all 0.3s ease;
                aspect-ratio: 16/9;
            }

            .cctv-card:hover {
                border-color: rgba(99, 102, 241, 0.5);
                box-shadow: 0 8px 32px rgba(99, 102, 241, 0.2);
                transform: translateY(-2px);
            }

            .cctv-video-wrapper {
                position: relative;
                width: 100%;
                height: 100%;
            }

            .cctv-video {
                width: 100%;
                height: 100%;
                object-fit: cover;
                background: #000;
            }

            .cctv-loading {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                text-align: center;
                z-index: 10;
            }

            .loading-spinner {
                border: 3px solid rgba(99, 102, 241, 0.1);
                border-top: 3px solid rgb(99, 102, 241);
                border-radius: 50%;
                width: 40px;
                height: 40px;
                animation: spin 1s linear infinite;
                margin: 0 auto;
            }

            @keyframes spin {
                0% {
                    transform: rotate(0deg);
                }

                100% {
                    transform: rotate(360deg);
                }
            }

            .cctv-overlay {
                position: absolute;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: linear-gradient(to bottom, rgba(0, 0, 0, 0.6) 0%, transparent 30%, transparent 70%, rgba(0, 0, 0, 0.7) 100%);
                display: flex;
                flex-direction: column;
                justify-content: space-between;
                padding: 1rem;
                opacity: 1;
                transition: opacity 0.3s ease;
            }

            .live-badge {
                align-self: flex-start;
                background: rgba(239, 68, 68, 0.9);
                color: white;
                padding: 0.25rem 0.75rem;
                border-radius: 6px;
                font-size: 0.75rem;
                font-weight: 600;
                letter-spacing: 0.5px;
                animation: pulse 2s ease-in-out infinite;
            }

            @keyframes pulse {

                0%,
                100% {
                    opacity: 1;
                }

                50% {
                    opacity: 0.7;
                }
            }

            .cctv-info {
                align-self: flex-start;
            }

            .expand-button {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                background: rgba(99, 102, 241, 0.2);
                backdrop-filter: blur(10px);
                border: 2px solid rgb(99, 102, 241);
                color: rgb(99, 102, 241);
                padding: 0.75rem;
                border-radius: 50%;
                cursor: pointer;
                transition: all 0.3s ease;
                opacity: 0;
            }

            .cctv-card:hover .expand-button {
                opacity: 1;
            }

            .expand-button:hover {
                background: rgba(99, 102, 241, 0.3);
                transform: translate(-50%, -50%) scale(1.1);
            }

            .hide-camera-button {
                position: absolute;
                top: 0.75rem;
                right: 0.75rem;
                z-index: 20;
                background: rgba(0, 0, 0, 0.58);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255, 255, 255, 0.28);
                color: white;
                padding: 0.55rem;
                border-radius: 8px;
                cursor: pointer;
                transition: all 0.2s ease;
                opacity: 0;
            }

            .cctv-card:hover .hide-camera-button {
                opacity: 1;
            }

            .hide-camera-button:hover {
                background: rgba(220, 38, 38, 0.9);
                transform: scale(1.06);
            }

            .hide-camera-button.is-hidden:hover {
                background: rgba(22, 163, 74, 0.9);
            }

            .cctv-card.camera-hidden {
                opacity: 0.55;
            }

            .hidden-camera-badge {
                position: absolute;
                top: 0.75rem;
                left: 5.25rem;
                z-index: 20;
                background: rgba(220, 38, 38, 0.88);
                color: white;
                padding: 0.25rem 0.6rem;
                border-radius: 999px;
                font-size: 0.65rem;
                font-weight: 800;
                letter-spacing: 0.04em;
                text-transform: uppercase;
            }

            /* Modal Styles */
            .modal-overlay {
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                bottom: 0;
                background: rgba(0, 0, 0, 0.9);
                z-index: 9999;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 2rem;
            }

            .modal-overlay.hidden {
                display: none;
            }

            .modal-content {
                position: relative;
                width: 100%;
                max-width: 1200px;
                background: rgba(26, 31, 58, 0.95);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 16px;
                overflow: hidden;
            }

            .modal-close {
                position: absolute;
                top: 1rem;
                right: 1rem;
                background: rgba(239, 68, 68, 0.9);
                border: none;
                color: white;
                width: 40px;
                height: 40px;
                border-radius: 50%;
                font-size: 1.5rem;
                cursor: pointer;
                z-index: 10;
                transition: all 0.3s ease;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .modal-close:hover {
                background: rgb(239, 68, 68);
                transform: rotate(90deg);
            }

            .modal-video-container {
                position: relative;
                aspect-ratio: 16/9;
            }

            .modal-video {
                width: 100%;
                height: 100%;
                object-fit: contain;
                background: #000;
            }

            .modal-info {
                position: absolute;
                bottom: 1rem;
                left: 1rem;
                background: rgba(0, 0, 0, 0.7);
                backdrop-filter: blur(10px);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 8px;
                padding: 0.75rem 1rem;
            }
        </style>

        <div class="glass-card">
            <div class="px-4 py-5 sm:px-6 border-b border-white/10 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
                <div>
                    <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-gray-100">Monitor CCTV</h3>
                    <p class="mt-1 max-w-2xl text-sm text-gray-600 dark:text-gray-400" id="monitor-desc">Sistem monitoring CCTV lokal area gang</p>
                </div>
                <!-- Buttons -->
                <div class="flex flex-row flex-wrap gap-2">
                    <a href="https://wa.me/?text=Pantau%20CCTV%20Lalu%20Lintas%20dan%20Area%20Warga%20secara%20langsung%20di%20sini:%20https://gang.ambyar.biz.id/cctv/monitor" target="_blank" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-green-800 bg-green-100 hover:bg-green-200 dark:text-white dark:bg-green-600 dark:hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-colors duration-200">
                        <svg class="mr-2 -ml-1 h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z" />
                        </svg>
                        Share WA
                    </a>
                    <a href="https://cctv.ambyar.biz.id/" target="_blank" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-indigo-800 bg-indigo-100 hover:bg-indigo-200 dark:text-white dark:bg-indigo-600 dark:hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200">
                        <svg class="mr-2 -ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                        Buka CCTV Gang
                    </a>
                    <% if (user) { %>
                        <button type="button" id="sirenButton" onclick="triggerGangSiren()" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-red-800 bg-red-100 hover:bg-red-200 dark:text-white dark:bg-red-600 dark:hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors duration-200">
                            <svg class="mr-2 -ml-1 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M4.93 19h14.14c1.54 0 2.5-1.67 1.73-3L13.73 4c-.77-1.33-2.69-1.33-3.46 0L3.2 16c-.77 1.33.19 3 1.73 3z" />
                            </svg>
                            Lampu alarm CCTV
                        </button>
                    <% } %>
                </div>
            </div>

            <!-- Tabs -->
            <div class="border-b border-white/10">
                <nav class="-mb-px flex space-x-8 px-4 sm:px-6 overflow-x-auto" aria-label="Tabs">
                    <button id="tab-frigate" class="border-indigo-500 text-indigo-400 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors duration-200" onclick="switchTab('frigate')">
                        CCTV Gang
                    </button>
                    <button id="tab-lalu-lintas" class="border-transparent text-gray-400 hover:text-gray-300 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors duration-200" onclick="switchTab('lalu-lintas')">
                        CCTV Lalu Lintas
                    </button>
                </nav>
            </div>

            <div class="p-6">
                <!-- MSE Go2RTC Content -->
                <div id="content-frigate" class="block">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="frigateGrid"></div>
                </div>

                <!-- CCTV Lalu Lintas Content -->
                <div id="content-lalu-lintas" class="hidden">
                    <!-- CCTV Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="cctvGrid"></div>
                </div>
            </div>
        </div>

        <!-- Modal -->
        <div class="modal-overlay hidden" id="modalOverlay" onclick="closeModal()">
            <div class="modal-content" onclick="event.stopPropagation()">
                <button class="modal-close" onclick="closeModal()">×</button>
                <div class="modal-video-container">
                    <video class="modal-video" id="modalVideo" style="display: none;" autoplay muted controls></video>
                    <iframe id="modalIframe" class="modal-video border-0" style="display: none;" allow="autoplay; fullscreen"></iframe>
                    <img id="modalImage" class="modal-video" style="display: none; object-fit: cover;" alt="">
                    <div class="modal-info pointer-events-none">
                        <div class="text-sm font-bold text-white drop-shadow-md"
                            style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);"
                            id="modalCameraName"></div>
                        <div class="text-xs text-white font-bold drop-shadow-md mt-1"
                            style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);"
                            id="modalCameraId"></div>
                    </div>
                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
        <script>
            const isAdmin = <%- JSON.stringify(Boolean(user && user.role === 'admin')) %>;
            const hiddenCameras = new Set(<%- JSON.stringify(typeof hiddenCameras !== 'undefined' ? hiddenCameras : []) %>);

            // Camera Data
            const cameras = [
                { id: 'CT-01', name: 'Tambun Selatan (Showroom MG)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-01/index.m3u8' },
                { id: 'CT-02', name: 'RSUD Kab Bekasi (Cibitung)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-02/index.m3u8' },
                { id: 'CT-03', name: 'Stasiun Lemah Abang', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-03/index.m3u8' },
                { id: 'CT-04', name: 'U-Turn Besar Perum BCL (Pintu Kereta Perum Graha Asri)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-04/index.m3u8' },
                { id: 'CT-05', name: 'Pintu Kereta Citarik (Michelin)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-05/index.m3u8' },
                { id: 'CT-06', name: 'KPU Kab Bekasi', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-06/index.m3u8' },
                { id: 'CT-07', name: 'RS DKH Kedungwaringin (Hino Showroom)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-07/index.m3u8' },
                { id: 'CT-08', name: 'Jalan Lingkar Karawang (Hadap Cikarang)', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-08/index.m3u8' },
                { id: 'CT-09', name: 'Pintu TOL Klari', url: 'https://its.binamarga.pu.go.id:8989/play/hls/CT-09/index.m3u8' }
            ];

            // Initialize HLS Player
            function initHLS(video, url) {
                if (Hls.isSupported()) {
                    const hls = new Hls({
                        enableWorker: true,
                        lowLatencyMode: true,
                        backBufferLength: 90
                    });
                    hls.loadSource(url);
                    hls.attachMedia(video);
                    return hls;
                } else if (video.canPlayType('application/vnd.apple.mpegurl')) {
                    video.src = url;
                    return null;
                }
            }

            // Create CCTV Cards
            const grid = document.getElementById('cctvGrid');
            cameras.forEach(camera => {
                const card = document.createElement('div');
                card.className = 'cctv-card';
                card.innerHTML = `
            <div class="cctv-video-wrapper">
                <video class="cctv-video" autoplay muted playsinline></video>
                <div class="cctv-loading">
                    <div class="loading-spinner"></div>
                    <div class="text-xs text-white font-bold drop-shadow-md mt-2" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">Connecting...</div>
                </div>
                <div class="cctv-overlay">
                    <div class="live-badge">● LIVE</div>
                    <div class="cctv-info">
                        <div class="text-xs text-white font-bold drop-shadow-md" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${camera.id}</div>
                        <div class="text-sm text-white font-bold drop-shadow-md" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${camera.name}</div>
                    </div>
                    <button class="expand-button" onclick="openModal('${camera.id}')">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path>
                        </svg>
                    </button>
                </div>
            </div>
        `;

                const video = card.querySelector('.cctv-video');
                const loading = card.querySelector('.cctv-loading');
                video.muted = true;
                video.defaultMuted = true;

                // Initialize HLS
                const hls = initHLS(video, camera.url);

                // Hide loading when video starts
                video.addEventListener('loadeddata', () => {
                    loading.style.display = 'none';
                });

                grid.appendChild(card);
            });

            // Frigate Camera Data
            const go2rtcBaseUrl = 'https://camera.ambyar.biz.id';
            const frigateCameras = [
                { id: 'CCTV-GANG', name: 'CCTV Birds Eye View', src: 'cctv_gang_ambyar', type: 'mse' },
                { id: 'KALULA-HOME', name: 'CCTV Kalula Home (Snapshot)', src: 'cctv_kalula_home', type: 'snapshot' },
                { id: 'KALULA-HOME-LIVE', name: 'CCTV Kalula Home (Live)', src: 'cctv_kalula_home', type: 'mse' },
                { id: 'SECURITY-CAM', name: 'Security Camera', src: 'security_camera', type: 'mse' }
            ];

            function mseStreamUrl(src) {
                return `${go2rtcBaseUrl}/stream.html?src=${encodeURIComponent(src)}&mode=mse&media=video&muted=1`;
            }

            function frameUrl(src) {
                return `${go2rtcBaseUrl}/api/frame.jpeg?src=${encodeURIComponent(src)}&_=${Date.now()}`;
            }

            function startSnapshotRefresh(img, src, intervalMs = 5000) {
                const refresh = () => {
                    img.src = frameUrl(src);
                };
                refresh();
                return window.setInterval(refresh, intervalMs);
            }

            function adminHideButton(camera) {
                if (!isAdmin) return '';
                const hidden = hiddenCameras.has(camera.src);
                const title = hidden ? 'Tampilkan kamera' : 'Sembunyikan kamera';
                const iconPath = hidden
                    ? 'M3 3l18 18M10.584 10.587A2 2 0 0012 14a2 2 0 001.412-.584M9.88 4.24A9.85 9.85 0 0112 4c4.478 0 8.268 2.943 9.542 7a10.515 10.515 0 01-3.07 4.568M6.11 6.11A10.506 10.506 0 002.458 11C3.732 15.057 7.523 18 12 18c1.347 0 2.633-.268 3.807-.754'
                    : 'M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z';

                return `
                    <button class="hide-camera-button ${hidden ? 'is-hidden' : ''}" onclick="toggleCameraHidden('${camera.src}', event)" title="${title}" aria-label="${title}">
                        <svg class="w-5 h-5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="${iconPath}"></path>
                        </svg>
                    </button>
                `;
            }

            function hiddenCameraBadge(camera) {
                return isAdmin && hiddenCameras.has(camera.src) ? '<div class="hidden-camera-badge">Hidden</div>' : '';
            }

            // Create Frigate Cards
            const frigateGrid = document.getElementById('frigateGrid');
            frigateCameras.forEach(camera => {
                if (!isAdmin && hiddenCameras.has(camera.src)) return;

                const card = document.createElement('div');
                card.className = `cctv-card${hiddenCameras.has(camera.src) ? ' camera-hidden' : ''}`;
                const mediaHtml = camera.type === 'snapshot'
                    ? `<img class="cctv-video" alt="${camera.name}" style="object-fit: cover;">`
                    : `<iframe src="${mseStreamUrl(camera.src)}" class="cctv-video pointer-events-none border-0" title="${camera.name}" allow="autoplay; fullscreen" onload="this.nextElementSibling.style.display='none'"></iframe>`;
                card.innerHTML = `
            <div class="cctv-video-wrapper">
                ${mediaHtml}
                ${hiddenCameraBadge(camera)}
                <div class="cctv-loading">
                    <div class="loading-spinner"></div>
                    <div class="text-xs text-white font-bold drop-shadow-md mt-2" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">Connecting...</div>
                </div>
                <div class="cctv-overlay">
                    <div class="live-badge">● LIVE</div>
                    <div class="cctv-info">
                        <div class="text-xs text-white font-bold drop-shadow-md" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${camera.id}</div>
                        <div class="text-sm text-white font-bold drop-shadow-md" style="color: #ffffff !important; text-shadow: 0 1px 2px rgba(0,0,0,0.8);">${camera.name}</div>
                    </div>
                    <button class="expand-button" onclick="openFrigateModal('${camera.id}')">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"></path>
                        </svg>
                    </button>
                    ${adminHideButton(camera)}
                </div>
            </div>
        `;
                if (camera.type === 'snapshot') {
                    const img = card.querySelector('img.cctv-video');
                    const loading = card.querySelector('.cctv-loading');
                    img.addEventListener('load', () => {
                        loading.style.display = 'none';
                    });
                    startSnapshotRefresh(img, camera.src);
                }
                frigateGrid.appendChild(card);
            });

            async function toggleCameraHidden(cameraSrc, event) {
                event.stopPropagation();
                const shouldHide = !hiddenCameras.has(cameraSrc);
                const actionText = shouldHide ? 'sembunyikan' : 'tampilkan kembali';

                if (!confirm(`Yakin ingin ${actionText} kamera ini?`)) return;

                try {
                    const response = await fetch('/cctv/hide-camera', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json'
                        },
                        body: JSON.stringify({
                            camera_id: cameraSrc,
                            hidden: shouldHide
                        })
                    });
                    const result = await response.json();

                    if (!response.ok || !result.success) {
                        throw new Error(result.message || 'Gagal menyimpan status kamera.');
                    }

                    window.location.reload();
                } catch (error) {
                    alert(error.message || 'Gagal menyimpan status kamera.');
                }
            }

            // Modal Functions
            let modalHls = null;
            let modalSnapshotTimer = null;

            function openModal(cameraId) {
                const camera = cameras.find(c => c.id === cameraId);
                if (!camera) return;

                const modal = document.getElementById('modalOverlay');
                const video = document.getElementById('modalVideo');
                const iframe = document.getElementById('modalIframe');
                const image = document.getElementById('modalImage');

                document.getElementById('modalCameraName').textContent = camera.name;
                document.getElementById('modalCameraId').textContent = camera.id;

                video.style.display = 'block';
                iframe.style.display = 'none';
                image.style.display = 'none';
                video.muted = true;
                video.defaultMuted = true;
                iframe.src = '';
                image.src = '';

                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';

                if (modalSnapshotTimer) {
                    clearInterval(modalSnapshotTimer);
                    modalSnapshotTimer = null;
                }

                if (modalHls) {
                    modalHls.destroy();
                }

                modalHls = initHLS(video, camera.url);
            }

            function openFrigateModal(cameraId) {
                const camera = frigateCameras.find(c => c.id === cameraId);
                if (!camera) return;

                const modal = document.getElementById('modalOverlay');
                const video = document.getElementById('modalVideo');
                const iframe = document.getElementById('modalIframe');
                const image = document.getElementById('modalImage');

                document.getElementById('modalCameraName').textContent = camera.name;
                document.getElementById('modalCameraId').textContent = camera.id;

                iframe.style.display = camera.type === 'snapshot' ? 'none' : 'block';
                image.style.display = camera.type === 'snapshot' ? 'block' : 'none';
                video.style.display = 'none';
                if (modalHls) {
                    modalHls.destroy();
                    modalHls = null;
                }
                if (modalSnapshotTimer) {
                    clearInterval(modalSnapshotTimer);
                    modalSnapshotTimer = null;
                }
                video.pause();
                video.removeAttribute('src');
                video.load();
                if (camera.type === 'snapshot') {
                    iframe.src = '';
                    image.alt = camera.name;
                    modalSnapshotTimer = startSnapshotRefresh(image, camera.src, 3000);
                } else {
                    image.src = '';
                    iframe.src = mseStreamUrl(camera.src);
                }

                modal.classList.remove('hidden');
                document.body.style.overflow = 'hidden';
            }

            function closeModal() {
                const modal = document.getElementById('modalOverlay');
                const video = document.getElementById('modalVideo');
                const iframe = document.getElementById('modalIframe');
                const image = document.getElementById('modalImage');

                modal.classList.add('hidden');
                document.body.style.overflow = '';

                if (modalSnapshotTimer) {
                    clearInterval(modalSnapshotTimer);
                    modalSnapshotTimer = null;
                }
                if (modalHls) {
                    modalHls.destroy();
                    modalHls = null;
                }
                video.pause();
                video.removeAttribute('src');
                video.load();
                image.removeAttribute('src');
                image.style.display = 'none';
                
                iframe.src = '';
            }

            // Close modal on ESC key
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape') closeModal();
            });

            // Tab Switching Logic
            function switchTab(tab) {
                const tabLaluLintas = document.getElementById('tab-lalu-lintas');
                const tabFrigate = document.getElementById('tab-frigate');
                const contentLaluLintas = document.getElementById('content-lalu-lintas');
                const contentFrigate = document.getElementById('content-frigate');
                const desc = document.getElementById('monitor-desc');
                const sirenButton = document.getElementById('sirenButton');

                const activeTabClass = 'border-indigo-500 text-indigo-400 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors duration-200';
                const inactiveTabClass = 'border-transparent text-gray-400 hover:text-gray-300 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors duration-200';

                if (tab === 'lalu-lintas') {
                    tabLaluLintas.className = activeTabClass;
                    tabFrigate.className = inactiveTabClass;
                    
                    contentLaluLintas.className = 'block';
                    contentFrigate.className = 'hidden';
                    
                    desc.textContent = 'Live streaming dari 9 titik kamera CCTV di area perjalanan kerja';
                    if (sirenButton) sirenButton.classList.add('hidden');
                } else if (tab === 'frigate') {
                    tabFrigate.className = activeTabClass;
                    tabLaluLintas.className = inactiveTabClass;
                    
                    contentFrigate.className = 'block';
                    contentLaluLintas.className = 'hidden';
                    
                    desc.textContent = 'Sistem monitoring CCTV lokal area gang';
                    if (sirenButton) sirenButton.classList.remove('hidden');
                }
            }

            async function triggerGangSiren() {
                if (!confirm('Nyalakan siren CCTV Gang sekarang?')) return;

                const button = document.getElementById('sirenButton');
                const originalContent = button ? button.innerHTML : '';
                if (button) {
                    button.disabled = true;
                    button.innerHTML = 'Menyalakan...';
                }

                try {
                    const response = await fetch('/cctv/siren', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify({ entity_id: 'siren.camera_gcc2_f7f8_siren' })
                    });
                    const result = await response.json();

                    if (!response.ok || !result.success) {
                        throw new Error(result.message || 'Gagal menyalakan siren.');
                    }

                    alert(result.message || 'Siren CCTV Gang dinyalakan.');
                } catch (error) {
                    alert('Gagal menyalakan siren: ' + error.message);
                } finally {
                    if (button) {
                        button.disabled = false;
                        button.innerHTML = originalContent;
                    }
                }
            }
        </script>

