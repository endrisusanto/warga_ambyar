            <!-- Tabs -->
            <div class="border-b border-white/10">
                <nav class="-mb-px flex space-x-8 px-4 sm:px-6 overflow-x-auto" aria-label="Tabs">
                    <button id="tab-lalu-lintas" class="border-indigo-500 text-indigo-400 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors duration-200" onclick="switchTab('lalu-lintas')">
                        CCTV Lalu Lintas
                    </button>
                    <button id="tab-frigate" class="border-transparent text-gray-400 hover:text-gray-300 hover:border-gray-300 whitespace-nowrap py-4 px-1 border-b-2 font-medium text-sm transition-colors duration-200" onclick="switchTab('frigate')">
