<%- include('../partials/head') %>
    <title><%= title %></title>
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="<%= description %>">
    <% if(ogImage) { %>
        <meta property="og:image" content="<%= ogImage %>">
        <meta property="og:image:url" content="<%= ogImage %>">
        <meta property="og:image:secure_url" content="<%= ogImage %>">
        <meta property="og:image:type" content="image/jpeg">
        <meta property="og:image:width" content="600">
        <meta property="og:image:height" content="800">
    <% } %>
    </head>

    <body class="bg-white min-h-screen text-gray-900 font-sans selection:bg-indigo-500 selection:text-white">

        <!-- Background Effects -->
        <div class="fixed inset-0 z-0 overflow-hidden pointer-events-none">
            <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] rounded-full bg-indigo-400/20 blur-[100px]"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-purple-400/20 blur-[100px]"></div>
        </div>

        <div class="relative z-10 max-w-4xl mx-auto px-4 py-8 sm:px-6 lg:px-8 flex flex-col items-center justify-center min-h-screen">

            <div class="w-full text-center mb-8">
                <h1 class="text-3xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-500 to-purple-500 drop-shadow-sm mb-2">
                    Bukti Pembayaran
                </h1>
                <p class="text-gray-500 text-sm font-medium">
                    <%= donasi.campaign_judul %>
                </p>
            </div>

            <div class="w-full p-4 sm:p-8 rounded-2xl overflow-hidden shadow-2xl border border-gray-200 bg-white relative">

                <!-- Detail Pembayaran Header -->
                <div class="p-6">
                    <h3 class="text-lg leading-6 font-medium !text-gray-900 mb-4 text-center">Detail Pembayaran</h3>
                    
                    <!-- Donatur Info -->
                    <div class="text-center mb-6">
                        <div class="w-16 h-16 rounded-full bg-indigo-500/20 flex items-center justify-center text-indigo-500 font-bold text-2xl mx-auto mb-3">
                            <%= donasi.nama_donatur.charAt(0).toUpperCase() %>
                        </div>
                        <p class="text-lg font-bold text-gray-900"><%= donasi.nama_donatur %></p>
                        <% if(donasi.is_anonim) { %>
                            <span class="text-xs bg-purple-100 text-purple-600 px-2 py-0.5 rounded-full">🕶️ Anonim</span>
                        <% } %>
                    </div>

                    <!-- Amount -->
                    <div class="text-center mb-6">
                        <p class="text-3xl font-bold text-gray-900">Rp <%= parseFloat(donasi.jumlah).toLocaleString('id-ID') %></p>
                    </div>

                    <!-- Timeline -->
                    <div class="py-2 flex justify-center mb-4">
                        <div class="flex items-center bg-gray-200 rounded-full px-1 py-1 flex-wrap justify-center gap-1">
                            <!-- Info Date -->
                            <div class="flex items-center gap-2 px-3 py-1">
                                <span class="text-xs text-gray-600 font-bold uppercase tracking-wider">Pembayaran</span>
                                <span class="text-xs text-gray-700"><%= moment(donasi.created_at).locale('id').format('D MMM YYYY, HH:mm') %></span>
                            </div>
                            
                            <% if (donasi.verified_at) { %>
                                <!-- Arrow -->
                                <div class="px-1 text-gray-600">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                    </svg>
                                </div>
                                <!-- Verified Pill -->
                                <div class="flex items-center gap-2 px-3 py-1 bg-emerald-100 rounded-full border border-emerald-200">
                                    <span class="text-xs text-emerald-700 font-bold uppercase tracking-wider">Verified</span>
                                    <span class="text-xs text-emerald-600 font-medium"><%= moment(donasi.verified_at).locale('id').format('D MMM YYYY, HH:mm') %></span>
                                </div>
                            <% } %>
                        </div>
                    </div>

                    <!-- Status Badge -->
                    <div class="flex items-center gap-2 justify-center mb-6">
                        <% if(donasi.status === 'verified') { %>
                            <span class="px-3 py-1 rounded-full text-xs font-semibold bg-emerald-500/20 text-emerald-600 border border-emerald-500/30">✅ TERVERIFIKASI</span>
                        <% } else if(donasi.status === 'pending') { %>
                            <span class="px-3 py-1 bg-yellow-100 text-yellow-700 rounded-full text-xs font-bold border border-yellow-200">⏳ MENUNGGU VERIFIKASI</span>
                        <% } else { %>
                            <span class="px-3 py-1 bg-red-100 text-red-700 rounded-full text-xs font-bold border border-red-200 uppercase"><%= donasi.status %></span>
                        <% } %>
                    </div>

                    <!-- Payment Method Badge -->
                    <% if(donasi.metode_bayar) { %>
                        <div class="flex items-center gap-2 justify-center mb-6">
                            <% if(donasi.metode_bayar === 'DANA') { %>
                                <span class="px-3 py-1 rounded-full text-xs font-semibold bg-[#118EE9]/20 text-[#118EE9] border border-[#118EE9]/30"><%= donasi.metode_bayar %></span>
                            <% } else if(donasi.metode_bayar === 'QRIS') { %>
                                <span class="px-3 py-1 rounded-full text-xs font-semibold bg-emerald-500/20 text-emerald-600 border border-emerald-500/30"><%= donasi.metode_bayar %></span>
                            <% } else if(donasi.metode_bayar === 'Tunai') { %>
                                <span class="px-3 py-1 rounded-full text-xs font-semibold bg-amber-500/20 text-amber-600 border border-amber-500/30"><%= donasi.metode_bayar %></span>
                            <% } else { %>
                                <span class="px-3 py-1 rounded-full text-xs font-semibold bg-gray-200 text-gray-700 border border-gray-300"><%= donasi.metode_bayar %></span>
                            <% } %>
                        </div>
                    <% } %>

                    <!-- Message -->
                    <% if(donasi.pesan) { %>
                        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-6">
                            <p class="text-xs font-bold text-gray-500 mb-1">💬 Pesan:</p>
                            <p class="text-sm text-gray-700 italic">"<%= donasi.pesan %>"</p>
                        </div>
                    <% } %>

                    <!-- Proof Image -->
                    <% if(donasi.bukti_bayar) { %>
                        <div class="border border-gray-200 rounded-xl p-3 bg-gray-50">
                            <p class="text-xs font-bold mb-2 text-gray-700">📷 Bukti Pembayaran:</p>
                            <img src="/uploads/donasi/bukti/<%= donasi.bukti_bayar %>" class="w-full object-contain max-h-96 rounded-lg mb-2">
                            <a href="/uploads/donasi/bukti/<%= donasi.bukti_bayar %>" target="_blank" class="block text-gray-600 text-xs hover:underline text-center mb-2">Lihat Ukuran Penuh</a>
                        </div>
                    <% } %>

                    <!-- Campaign Info -->
                    <div class="mt-6 bg-indigo-50 border border-indigo-200 rounded-xl p-4">
                        <p class="text-xs font-bold text-indigo-500 mb-1">🎯 Campaign:</p>
                        <a href="/donasi/campaign/<%= donasi.campaign_id %>" class="text-sm font-bold text-indigo-700 hover:underline"><%= donasi.campaign_judul %></a>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="mt-8 pt-6 border-t border-gray-100 flex gap-3">
                    <button onclick="copyLink()"
                        class="flex-1 flex justify-center items-center px-4 py-3 bg-gray-100 hover:bg-gray-200 border border-gray-200 rounded-xl text-sm font-bold text-gray-700 hover:text-gray-900 transition-all">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z">
                            </path>
                        </svg>
                        Copy Link
                    </button>
                    <button onclick="shareWa()"
                        class="flex-1 flex justify-center items-center px-4 py-3 bg-emerald-600/80 hover:bg-emerald-600 border border-emerald-500/50 rounded-xl text-sm font-bold text-white transition-all shadow-lg shadow-emerald-900/20 backdrop-blur-sm">
                        <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                            <path
                                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                        </svg>
                        Share WA
                    </button>
                </div>

            </div>

            <!-- Home Button & Footer -->
            <div class="mt-8 flex flex-col items-center gap-4">
                <a href="/donasi/campaign/<%= donasi.campaign_id %>"
                    class="flex items-center px-6 py-3 bg-gray-100 hover:bg-gray-200 border border-gray-200 rounded-full text-sm font-bold text-gray-700 hover:text-gray-900 transition-all shadow-lg">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M11 17l-5-5m0 0l5-5m-5 5h12"></path>
                    </svg>
                    Kembali ke Campaign
                </a>

                <div class="flex items-center gap-2 text-xs text-gray-500 font-medium tracking-wider uppercase">
                    <span>Powered by</span>
                    <span class="font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-400 to-purple-400">Warga Ambyar</span>
                </div>
            </div>
        </div>

        <script>
            function copyLink() {
                navigator.clipboard.writeText(window.location.href).then(() => alert('Link copied!'));
            }
            function shareWa() {
                const nama = '<%= donasi.nama_donatur %>';
                const jumlah = 'Rp <%= parseFloat(donasi.jumlah).toLocaleString("id-ID") %>';
                const campaign = '<%= donasi.campaign_judul %>';
                const tanggal = '<%= moment(donasi.created_at).locale("id").format("D MMM YYYY, HH:mm") %>';
                const message = `*Bukti Pembayaran - ${campaign}*\n\n👤 Pembayar: ${nama}\n💰 Jumlah: ${jumlah}\n📅 Tanggal: ${tanggal}\n✅ Status: Terverifikasi\n\n🔗 Detail: ${window.location.href}`;
                
                const encodedMessage = encodeURIComponent(message);
                window.open(`https://wa.me/?text=${encodedMessage}`, '_blank');
            }
        </script>

    </body>

    </html>
