<%- include('../partials/head') %>
    <%- include('../partials/navbar') %>

        <div class="max-w-4xl mx-auto py-6 sm:px-6 lg:px-8">
            <div class="glass-card p-8 m-4">
                <h2 class="text-3xl font-bold text-gray-900 dark:text-gray-100 mb-8 flex items-center gap-3">
                    <span class="text-4xl">📢</span>
                    Buat Campaign Donasi
                </h2>

                <form id="campaignForm" action="/donasi/campaign/store" method="POST" enctype="multipart/form-data">
                    <div class="mb-6">
                        <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2">Judul Campaign
                            *</label>
                        <input type="text" name="judul" required placeholder="Contoh: Bantuan Renovasi Masjid"
                            class="glass-input w-full py-3 px-4 text-gray-900 dark:text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-white/50 rounded-xl">
                    </div>

                    <div class="mb-6">
                        <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2">Deskripsi</label>
                        <div class="border border-gray-200 dark:border-white/10 rounded-xl overflow-hidden">
                            <div class="flex items-center gap-1 px-3 py-2 bg-gray-50 dark:bg-white/5 border-b border-gray-200 dark:border-white/10">
                                <button type="button" onclick="formatText('bold')" title="Bold" class="p-1.5 rounded-lg hover:bg-gray-200 dark:hover:bg-white/10 text-gray-600 dark:text-gray-400 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 4h8a4 4 0 014 4 4 4 0 01-4 4H6z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 12h9a4 4 0 014 4 4 4 0 01-4 4H6z"/></svg>
                                </button>
                                <button type="button" onclick="formatText('italic')" title="Italic" class="p-1.5 rounded-lg hover:bg-gray-200 dark:hover:bg-white/10 text-gray-600 dark:text-gray-400 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 4h4m-2 0l-4 16m0 0h4"/></svg>
                                </button>
                                <div class="w-px h-5 bg-gray-300 dark:bg-white/20 mx-1"></div>
                                <button type="button" onclick="formatText('bullet')" title="Bullet List" class="p-1.5 rounded-lg hover:bg-gray-200 dark:hover:bg-white/10 text-gray-600 dark:text-gray-400 transition-colors">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/><circle cx="2" cy="6" r="1" fill="currentColor"/><circle cx="2" cy="12" r="1" fill="currentColor"/><circle cx="2" cy="18" r="1" fill="currentColor"/></svg>
                                </button>
                                <button type="button" onclick="formatText('number')" title="Numbered List" class="p-1.5 rounded-lg hover:bg-gray-200 dark:hover:bg-white/10 text-gray-600 dark:text-gray-400 transition-colors">
                                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 6h13M8 12h13M8 18h13"/><text x="1" y="8" fill="currentColor" font-size="8" font-weight="bold" stroke="none">1</text><text x="1" y="14" fill="currentColor" font-size="8" font-weight="bold" stroke="none">2</text><text x="1" y="20" fill="currentColor" font-size="8" font-weight="bold" stroke="none">3</text></svg>
                                </button>
                            </div>
                            <textarea name="deskripsi" id="deskripsiInput" rows="5" placeholder="Jelaskan tujuan dan detail campaign..."
                                class="w-full py-3 px-4 text-gray-900 dark:text-gray-100 placeholder-gray-500 focus:outline-none bg-transparent border-0 resize-y"></textarea>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">Gunakan toolbar untuk format teks. *bold* _italic_ • bullet list</p>
                    </div>

                    <div class="mb-6">
                        <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2">Tipe Target</label>
                        
                        <div class="relative flex items-center p-1 bg-gray-200 dark:bg-gray-800 rounded-xl border border-gray-300 dark:border-white/10 mb-4 w-full">
                            <!-- Hidden inputs to submit data -->
                            <input type="radio" name="tipe_target" id="tipe_total" value="total" checked class="peer/total hidden">
                            <input type="radio" name="tipe_target" id="tipe_rumah" value="per_rumah" class="peer/rumah hidden">
                            
                            <!-- Sliding Background -->
                            <div class="absolute left-1 top-1 bottom-1 w-[calc(50%-4px)] bg-red-500 rounded-lg shadow-lg transition-transform duration-300 ease-in-out peer-checked/rumah:translate-x-full"></div>

                            <!-- Labels -->
                            <label for="tipe_total" class="relative flex-1 flex items-center justify-center py-2.5 px-3 cursor-pointer z-10 text-sm font-bold transition-all duration-300 text-white peer-checked/rumah:text-gray-900 dark:peer-checked/rumah:text-gray-100 text-center">
                                Total Dana Terkumpul
                            </label>
                            <label for="tipe_rumah" class="relative flex-1 flex items-center justify-center py-2.5 px-3 cursor-pointer z-10 text-sm font-bold transition-all duration-300 text-gray-900 dark:text-gray-100 peer-checked/rumah:text-white text-center">
                                Fixed Nominal / Rumah
                            </label>
                        </div>

                        <label id="label_nominal" class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2 transition-all duration-300">Nominal Target Dana Keseluruhan (Rp)</label>
                        <input type="text" id="input_nominal_display"
                            placeholder="Contoh: 5.000.000"
                            class="glass-input w-full py-3 px-4 text-gray-900 dark:text-gray-100 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-white/50 rounded-xl transition-all duration-300">
                        <input type="hidden" name="target_dana" id="input_nominal">
                        <p id="desc_nominal" class="text-xs text-gray-500 mt-1 transition-all duration-300">Kosongkan jika tidak ada target tertentu</p>
                    </div>

                        <script>
                        document.addEventListener('DOMContentLoaded', () => {
                            const radioTotal = document.getElementById('tipe_total');
                            const radioRumah = document.getElementById('tipe_rumah');
                            const labelNominal = document.getElementById('label_nominal');
                            const descNominal = document.getElementById('desc_nominal');
                            const inputNominal = document.getElementById('input_nominal');
                            const inputNominalDisplay = document.getElementById('input_nominal_display');

                            // Format number with dots
                            function formatNumber(num) {
                                return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
                            }

                            // Event listener for visual formatting
                            inputNominalDisplay.addEventListener('input', function(e) {
                                // Remove non-numeric characters for the actual value
                                let rawValue = this.value.replace(/[^0-9]/g, '');
                                
                                // Set the hidden input's value
                                inputNominal.value = rawValue;
                                
                                // Format the visible display
                                if(rawValue) {
                                    this.value = formatNumber(rawValue);
                                } else {
                                    this.value = '';
                                }
                            });

                            // Ensure hidden input syncs if user deletes everything
                            inputNominalDisplay.addEventListener('blur', function() {
                                if (!this.value) {
                                    inputNominal.value = '';
                                }
                            });

                            function updateNominalLabel() {
                                if (radioRumah.checked) {
                                    labelNominal.textContent = 'Nominal Tagihan Per Rumah (Rp) *';
                                    descNominal.textContent = 'Wajib diisi untuk menentukan besaran tagihan per rumah';
                                    inputNominalDisplay.placeholder = 'Contoh: 50.000';
                                    inputNominalDisplay.required = true;
                                } else {
                                    labelNominal.textContent = 'Nominal Target Dana Keseluruhan (Rp)';
                                    descNominal.textContent = 'Kosongkan jika tidak ada target tertentu';
                                    inputNominalDisplay.placeholder = 'Contoh: 5.000.000';
                                    inputNominalDisplay.required = false;
                                }
                            }

                            radioTotal.addEventListener('change', updateNominalLabel);
                            radioRumah.addEventListener('change', updateNominalLabel);
                            updateNominalLabel();
                        });
                    </script>

                    <div class="mb-6">
                        <label class="flex items-center cursor-pointer p-4 bg-gray-50 dark:bg-white/5 rounded-xl border border-gray-100 dark:border-white/10 transition-all hover:bg-gray-100 dark:hover:bg-white/10">
                            <!-- Switch body (from daisyUI style or custom tailwind config, we'll build a standard one) -->
                            <div class="relative">
                                <input type="checkbox" name="allow_anonim" id="allow_anonim" class="sr-only peer" checked>
                                <div class="w-11 h-6 bg-gray-200 peer-focus:outline-none rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:border-gray-600 peer-checked:bg-indigo-600"></div>
                            </div>
                            <div class="ml-4">
                                <span class="text-sm font-bold text-gray-700 dark:text-gray-300 block">Izinkan Donasi Anonim (Hamba Allah)</span>
                                <span class="text-xs text-gray-500">Jika diaktifkan, donatur dapat menyembunyikan nama mereka dari publik.</span>
                            </div>
                        </label>
                    </div>

                    <div class="mb-6">
                        <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2">Foto
                            Campaign</label>
                        <input type="file" id="fotoInput" accept="image/*"
                            class="glass-input w-full py-3 px-4 text-gray-900 dark:text-gray-100 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-gray-200 dark:bg-white/10 file:text-gray-900 dark:text-gray-100 hover:file:bg-white/20 focus:outline-none focus:ring-2 focus:ring-white/50 rounded-xl">
                        <div id="fotoPreview" class="mt-3 hidden">
                            <img id="fotoPreviewImg" class="h-32 rounded-lg border border-white/10" alt="Preview">
                            <p id="fotoSizeInfo" class="text-xs text-green-500 mt-1"></p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                        <div>
                            <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2">Tanggal Mulai
                                *</label>
                            <input type="datetime-local" name="tanggal_mulai" required
                                class="glass-input w-full py-3 px-4 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-white/50 rounded-xl">
                        </div>
                        <div>
                            <label class="block text-gray-700 dark:text-gray-300 text-sm font-bold mb-2">Tanggal Selesai
                                (Opsional)</label>
                            <input type="datetime-local" name="tanggal_selesai"
                                class="glass-input w-full py-3 px-4 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-white/50 rounded-xl">
                        </div>
                    </div>

                    <div class="flex items-center justify-end gap-4">
                        <a href="/donasi"
                            class="px-6 py-3 rounded-xl text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:bg-white/5 transition-all border border-white/10">
                            Batal
                        </a>
                        <button type="submit" id="submitBtn"
                            class="px-6 py-3 rounded-xl text-sm font-bold bg-white text-gray-900 border border-gray-200 shadow-sm hover:bg-gray-50 transform transition hover:-translate-y-0.5">
                            📢 Buat Campaign
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <script>
        function formatText(type) {
            const ta = document.getElementById('deskripsiInput');
            if (!ta) return;
            const start = ta.selectionStart;
            const end = ta.selectionEnd;
            const selected = ta.value.substring(start, end);
            let replacement = '';

            switch(type) {
                case 'bold':
                    replacement = selected ? `*${selected}*` : '*teks bold*';
                    break;
                case 'italic':
                    replacement = selected ? `_${selected}_` : '_teks italic_';
                    break;
                case 'bullet':
                    if (selected) {
                        replacement = selected.split('\n').map(l => `\u2022 ${l}`).join('\n');
                    } else {
                        replacement = '\u2022 ';
                    }
                    break;
                case 'number':
                    if (selected) {
                        replacement = selected.split('\n').map((l, i) => `${i+1}. ${l}`).join('\n');
                    } else {
                        replacement = '1. ';
                    }
                    break;
            }

            ta.focus();
            ta.setRangeText(replacement, start, end, 'end');
        }
        </script>

        <script>
        // === Client-side Image Compression for OG/WhatsApp compatibility ===
        (function() {
            const MAX_WIDTH = 1200;
            const MAX_HEIGHT = 900;
            const MAX_SIZE_KB = 500;
            const INITIAL_QUALITY = 0.8;

            const fotoInput = document.getElementById('fotoInput');
            const previewDiv = document.getElementById('fotoPreview');
            const previewImg = document.getElementById('fotoPreviewImg');
            const sizeInfo = document.getElementById('fotoSizeInfo');
            const form = document.getElementById('campaignForm');
            const submitBtn = document.getElementById('submitBtn');

            let compressedBlob = null;
            let compressedFileName = '';

            fotoInput.addEventListener('change', async function(e) {
                const file = e.target.files[0];
                if (!file) {
                    previewDiv.classList.add('hidden');
                    compressedBlob = null;
                    return;
                }

                const originalSizeKB = (file.size / 1024).toFixed(1);
                sizeInfo.textContent = `⏳ Mengkompres gambar (${originalSizeKB} KB)...`;
                sizeInfo.className = 'text-xs text-yellow-500 mt-1';
                previewDiv.classList.remove('hidden');

                try {
                    const result = await compressImage(file, MAX_WIDTH, MAX_HEIGHT, MAX_SIZE_KB);
                    compressedBlob = result.blob;
                    compressedFileName = file.name.replace(/\.[^.]+$/, '') + '.jpg';

                    previewImg.src = URL.createObjectURL(compressedBlob);
                    const newSizeKB = (compressedBlob.size / 1024).toFixed(1);
                    sizeInfo.textContent = `✅ Terkompres: ${originalSizeKB} KB → ${newSizeKB} KB (max 500 KB untuk WhatsApp)`;
                    sizeInfo.className = 'text-xs text-green-500 mt-1';
                } catch (err) {
                    console.error('Compression failed:', err);
                    sizeInfo.textContent = '⚠️ Gagal kompres, gambar asli akan digunakan';
                    sizeInfo.className = 'text-xs text-red-400 mt-1';
                    compressedBlob = null;
                }
            });

            form.addEventListener('submit', function(e) {
                if (compressedBlob) {
                    e.preventDefault();
                    submitBtn.disabled = true;
                    submitBtn.textContent = '⏳ Mengunggah...';

                    const formData = new FormData(form);
                    // Remove the old foto field (from hidden input if any)
                    formData.delete('foto');
                    // Add compressed blob as the foto
                    formData.append('foto', compressedBlob, compressedFileName);

                    fetch(form.action, {
                        method: 'POST',
                        body: formData,
                        redirect: 'follow'
                    }).then(response => {
                        if (response.redirected) {
                            window.location.href = response.url;
                        } else {
                            window.location.href = '/donasi';
                        }
                    }).catch(err => {
                        console.error('Upload failed:', err);
                        submitBtn.disabled = false;
                        submitBtn.textContent = '📢 Buat Campaign';
                        alert('Gagal mengunggah. Silakan coba lagi.');
                    });
                }
                // If no compressed blob (no image selected or compression failed), let normal form submit
            });

            function compressImage(file, maxW, maxH, maxSizeKB) {
                return new Promise((resolve, reject) => {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        const img = new Image();
                        img.onload = function() {
                            let w = img.width;
                            let h = img.height;

                            // Resize to fit within maxW x maxH
                            if (w > maxW || h > maxH) {
                                const ratio = Math.min(maxW / w, maxH / h);
                                w = Math.round(w * ratio);
                                h = Math.round(h * ratio);
                            }

                            const canvas = document.createElement('canvas');
                            canvas.width = w;
                            canvas.height = h;
                            const ctx = canvas.getContext('2d');
                            ctx.drawImage(img, 0, 0, w, h);

                            // Try progressively lower quality until under maxSizeKB
                            let quality = INITIAL_QUALITY;
                            function tryCompress() {
                                canvas.toBlob(function(blob) {
                                    if (!blob) return reject(new Error('Canvas toBlob failed'));
                                    
                                    if (blob.size / 1024 > maxSizeKB && quality > 0.3) {
                                        quality -= 0.1;
                                        tryCompress();
                                    } else {
                                        resolve({ blob, width: w, height: h });
                                    }
                                }, 'image/jpeg', quality);
                            }
                            tryCompress();
                        };
                        img.onerror = reject;
                        img.src = e.target.result;
                    };
                    reader.onerror = reject;
                    reader.readAsDataURL(file);
                });
            }
        })();
        </script>

