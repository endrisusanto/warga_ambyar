<%- include('../partials/head') %>
    <%- include('../partials/navbar') %>

        <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
            <div class="flex flex-col lg:flex-row gap-6 px-4 sm:px-0">
                <!-- Main Content -->
                <div class="lg:w-2/3">
                    <div class="glass-card overflow-hidden shadow-2xl">
                        <% if(campaign.foto) { %>
                            <div class="relative h-96 overflow-hidden">
                                <img src="/uploads/donasi/campaign/<%= campaign.foto %>"
                                    class="w-full h-full object-cover" alt="<%= campaign.judul %>">
                                <div class="absolute top-4 right-4">
                                    <% if(campaign.status==='aktif' ) { %>
                                        <span
                                            class="bg-green-500/90 text-white text-sm font-bold px-4 py-2 rounded-full">✅
                                            Aktif</span>
                                        <% } else if(campaign.status==='selesai' ) { %>
                                            <span
                                                class="bg-blue-500/90 text-white text-sm font-bold px-4 py-2 rounded-full">✔️
                                                Selesai</span>
                                            <% } else { %>
                                                <span
                                                    class="bg-gray-500/90 text-white text-sm font-bold px-4 py-2 rounded-full">🔒
                                                    Ditutup</span>
                                                <% } %>
                                </div>
                            </div>
                            <% } %>

                                <div class="p-6">
                                    <!-- Header with Title and Action Buttons -->
                                    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
                                        <h1 class="text-3xl font-black text-gray-900 dark:text-gray-100">
                                            <%= campaign.judul %>
                                        </h1>

                                        <!-- Action Buttons -->
                                        <div class="flex flex-wrap gap-2">
                                            <a href="/donasi"
                                                class="px-4 py-2 rounded-lg text-xs font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:bg-white/5 transition-all border border-white/10">
                                                ← Back
                                            </a>
                                            <!-- Share WhatsApp -->
                                            <a href="#" onclick="shareCampaignWA(); return false;"
                                                target="_blank"
                                                class="px-4 py-2 rounded-lg text-xs font-bold bg-green-500/10 hover:bg-green-500/20 text-green-400 border border-green-500/20 transition-all flex items-center gap-2">
                                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                                    <path
                                                        d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.506-.669-.516l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.017-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z" />
                                                </svg>
                                                Share WA
                                            </a>
                                            <% if(user && (user.role==='admin' || user.role==='ketua' || user.role==='bendahara')) { %>
                                                <a href="/donasi/campaign/<%= campaign.id %>/edit"
                                                    class="px-4 py-2 rounded-lg text-xs font-bold bg-indigo-500/10 hover:bg-indigo-500/20 text-indigo-400 border border-indigo-500/20 transition-all">
                                                    ✏️ Edit
                                                </a>
                                                <a href="/donasi/campaign/<%= campaign.id %>/neraca"
                                                    class="px-4 py-2 rounded-lg text-xs font-bold bg-purple-500/10 hover:bg-purple-500/20 text-purple-400 border border-purple-500/20 transition-all">
                                                    💰 Neraca
                                                </a>
                                                <a href="/donasi/campaign/<%= campaign.id %>/delete"
                                                    onclick="return confirm('Hapus campaign ini?')"
                                                    class="px-4 py-2 rounded-lg text-xs font-bold bg-red-500/10 hover:bg-red-500/20 text-red-400 border border-red-500/20 transition-all">
                                                    🗑️
                                                </a>
                                                <% } %>
                                        </div>
                                    </div>

                                    <% const terkumpul=parseFloat(campaign.terkumpul) || 0; const
                                        target=parseFloat(campaign.target_dana) || 0; const percentage=target> 0 ?
                                        Math.min((terkumpul / target) * 100, 100) : 0;
                                        %>

                                        <!-- Progress Section -->
                                        <% if (!campaign.tipe_target || campaign.tipe_target === 'total') { %>
                                            <div class="bg-gray-100 dark:bg-white/5 rounded-2xl p-6 mb-6">
                                                <div class="flex justify-between items-end mb-3">
                                                    <div>
                                                        <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Terkumpul</p>
                                                        <p class="text-3xl font-black text-green-400">Rp <%=
                                                                terkumpul.toLocaleString('id-ID') %>
                                                        </p>
                                                    </div>
                                                    <% if(target> 0) { %>
                                                        <div class="text-right">
                                                            <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Target</p>
                                                            <p class="text-xl font-bold text-gray-700 dark:text-gray-300">Rp <%=
                                                                    target.toLocaleString('id-ID') %>
                                                            </p>
                                                        </div>
                                                        <% } %>
                                                </div>
                                                <div class="w-full bg-gray-200 dark:bg-white/10 rounded-full h-3 overflow-hidden mb-2">
                                                    <div class="bg-gradient-to-r from-green-500 to-emerald-600 h-3 rounded-full transition-all duration-500"
                                                        style="width: <%= percentage %>%"></div>
                                                </div>
                                                <p class="text-sm text-gray-600 dark:text-gray-400">
                                                    <%= percentage.toFixed(1) %>% tercapai
                                                </p>
                                            </div>
                                        <% } else { %>
                                            <div class="bg-gray-100 dark:bg-white/5 rounded-2xl p-6 mb-6">
                                                <p class="text-sm text-gray-600 dark:text-gray-400 mb-1 font-bold">Target Nominal / Rumah</p>
                                                <p class="text-3xl font-black text-indigo-400 mb-4">Rp <%= target.toLocaleString('id-ID') %></p>
                                                
                                                <% 
                                                    const totalRumah = campaign.total_rumah || 1; 
                                                    const totalLunasData = donaturPerRumah.filter(d => d.total_bayar >= target).length;
                                                    const percentageRumah = Math.min((totalLunasData / totalRumah) * 100, 100);
                                                %>
                                                <div class="flex justify-between items-end mb-3 mt-4 pt-4 border-t border-gray-200 dark:border-white/10">
                                                    <div>
                                                        <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Total Dana Terkumpul</p>
                                                        <p class="text-2xl font-bold text-green-400">Rp <%= terkumpul.toLocaleString('id-ID') %></p>
                                                    </div>
                                                    <div class="text-right">
                                                        <p class="text-sm text-gray-600 dark:text-gray-400 mb-1">Progress Rumah Lunas</p>
                                                        <p class="text-xl font-bold text-gray-700 dark:text-gray-300"><%= totalLunasData %> / <%= totalRumah %></p>
                                                    </div>
                                                </div>
                                                <div class="w-full bg-gray-200 dark:bg-white/10 rounded-full h-3 overflow-hidden mb-2">
                                                    <div class="bg-gradient-to-r from-indigo-500 to-blue-600 h-3 rounded-full transition-all duration-500"
                                                        style="width: <%= percentageRumah %>%"></div>
                                                </div>
                                                <p class="text-xs text-gray-500 text-right"><%= percentageRumah.toFixed(1) %>% Rumah Lunas</p>
                                            </div>
                                        <% } %>

                                        <!-- Description -->
                                        <div class="mb-6">
                                            <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 mb-3">Deskripsi</h3>
                                            <div class="text-gray-700 dark:text-gray-300 whitespace-pre-line">
                                                <%= campaign.deskripsi || 'Tidak ada deskripsi' %>
                                            </div>
                                        </div>

                                        <!-- Timeline -->
                                        <div class="bg-gray-100 dark:bg-white/5 rounded-2xl p-6 mb-6">
                                            <h3 class="text-sm font-bold text-gray-900 dark:text-gray-100 mb-4">Waktu Pelaksanaan</h3>
                                            <% 
                                                const btnNow = moment();
                                                const btnStart = moment(campaign.tanggal_mulai);
                                                let timePercentage = 0;
                                                let timeLabel = '';
                                                let timeDesc = '';
                                                
                                                if (campaign.tanggal_selesai) {
                                                    const btnEnd = moment(campaign.tanggal_selesai);
                                                    if (btnNow.isBefore(btnStart)) {
                                                        timePercentage = 0;
                                                        timeLabel = 'Belum Dimulai';
                                                        timeDesc = 'Dimulai ' + btnStart.fromNow();
                                                    } else if (btnNow.isAfter(btnEnd)) {
                                                        timePercentage = 100;
                                                        timeLabel = 'Berakhir';
                                                        timeDesc = 'Selesai ' + btnEnd.fromNow();
                                                    } else {
                                                        const totalDuration = btnEnd.diff(btnStart);
                                                        const passedDuration = btnNow.diff(btnStart);
                                                        timePercentage = Math.max(0, Math.min((passedDuration / totalDuration) * 100, 100));
                                                        timeLabel = 'Sedang Berjalan';
                                                        timeDesc = 'Berakhir ' + btnEnd.fromNow();
                                                    }
                                                } else {
                                                    timePercentage = 100; // No end date = full bar
                                                    if (btnNow.isBefore(btnStart)) {
                                                        timeLabel = 'Belum Dimulai';
                                                        timeDesc = 'Dimulai ' + btnStart.fromNow();
                                                        timePercentage = 0;
                                                    } else {
                                                        timeLabel = 'Sedang Berjalan';
                                                        timeDesc = 'Tanpa Batas Waktu';
                                                    }
                                                }
                                            %>
                                            
                                            <div class="flex justify-between items-end mb-2">
                                                <div>
                                                    <p class="text-xs text-gray-500"><%= btnStart.format('DD MMM YYYY') %></p>
                                                </div>
                                                <div class="text-right">
                                                    <p class="text-xs text-gray-500"><%= campaign.tanggal_selesai ? moment(campaign.tanggal_selesai).format('DD MMM YYYY') : '∞' %></p>
                                                </div>
                                            </div>
                                            <div class="w-full bg-gray-200 dark:bg-white/10 rounded-full h-3 overflow-hidden mb-3">
                                                <div class="bg-gradient-to-r <%= timePercentage === 100 && campaign.tanggal_selesai ? 'from-gray-500 to-gray-600' : 'from-indigo-500 to-purple-600' %> h-3 rounded-full transition-all duration-500"
                                                    style="width: <%= timePercentage %>%"></div>
                                            </div>
                                            <div class="flex justify-between items-center">
                                                <p class="text-sm font-bold text-gray-800 dark:text-gray-200"><%= timeLabel %></p>
                                                <p class="text-xs font-semibold <%= timePercentage === 100 && campaign.tanggal_selesai ? 'text-red-400' : 'text-indigo-400' %>"><%= timeDesc %></p>
                                            </div>
                                        </div>

                                        <!-- Donasi Button (Only if Active) -->
                                        <% if(campaign.status==='aktif' ) { %>
                                            <div class="border-t border-white/10 pt-6">
                                                <a href="/donasi/campaign/<%= campaign.id %>/donate"
                                                    class="block w-full text-center px-8 py-4 rounded-xl text-base font-bold bg-gradient-to-r from-green-500 to-emerald-600 hover:from-green-600 hover:to-emerald-700 text-white shadow-lg transform transition hover:-translate-y-0.5">
                                                    💳 Bayar Sekarang
                                                </a>
                                            </div>
                                            <% } %>
                                </div>
                    </div>
                </div>

                <!-- Donatur List -->
                <div class="lg:w-1/3">
                    <div class="glass-card p-6 shadow-2xl sticky top-24">
                        <div class="flex items-center justify-between mb-4">
                            <h3 class="text-lg font-bold text-gray-900 dark:text-gray-100 flex items-center gap-2">
                                <svg class="w-5 h-5 text-indigo-400" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z">
                                    </path>
                                </svg>
                                Donatur (<%= campaign.jumlah_donatur %>)
                            </h3>
                            <div class="flex items-center gap-2">
                                <button onclick="shareAllDonaturWA()" title="Share semua list ke WA"
                                    class="p-2 rounded-lg bg-green-500/10 hover:bg-green-500/20 text-green-400 transition-colors">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981z"/></svg>
                                </button>
                                <% if(canViewReal) { %>
                                    <label class="flex items-center cursor-pointer">
                                        <input type="checkbox" <%=showReal ? 'checked' : '' %>
                                        onchange="window.location.href='/donasi/campaign/<%= campaign.id %>?showReal=' +
                                            this.checked"
                                            class="w-4 h-4 rounded border-white/20 bg-gray-100 dark:bg-white/5 text-indigo-600 focus:ring-2
                                            focus:ring-indigo-500/50">
                                            <span class="ml-2 text-xs text-gray-600 dark:text-gray-400">View Real</span>
                                    </label>
                                <% } %>
                            </div>
                        </div>

                        <div class="max-h-[600px] overflow-y-auto pr-2 custom-scrollbar">
                            <% if (campaign.tipe_target === 'per_rumah') { %>
                                <% if(donaturPerRumah.length === 0) { %>
                                    <div class="text-center py-8">
                                        <svg class="mx-auto h-12 w-12 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                                        </svg>
                                        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Belum ada data rumah</p>
                                    </div>
                                <% } else { %>
                                    <div class="space-y-3">
                                        <% donaturPerRumah.forEach(d => { %>
                                            <% const isLunas = parseFloat(d.total_bayar) >= parseFloat(campaign.target_dana); %>
                                            <% const namaDisplay = d.kepala_keluarga || d.daftar_penghuni || 'Tidak diketahui'; %>
                                            <% const buktiLink = d.last_transaksi_id ? `https://gang.ambyar.biz.id/donasi/v/${d.last_transaksi_id}` : `https://gang.ambyar.biz.id/donasi/campaign/${campaign.id}`; %>
                                            <div onclick="shareRumahWA(this)" data-judul="<%= campaign.judul %>" data-rumah="<%= d.rumah %>" data-nama="<%= namaDisplay %>" data-bayar="Rp <%= parseFloat(d.total_bayar).toLocaleString('id-ID') %>" data-lunas="<%= isLunas %>" data-link="<%= buktiLink %>"
                                                class="block bg-gray-100 dark:bg-white/5 rounded-xl p-4 border <%= isLunas ? 'border-green-500/30' : 'border-red-500/30' %> hover:bg-gray-200 dark:hover:bg-white/10 transition-all cursor-pointer group">
                                                <div class="flex items-start justify-between gap-3">
                                                    <div class="flex-1 min-w-0">
                                                        <div class="flex items-center gap-2 mb-2">
                                                            <p class="font-bold text-gray-800 dark:text-gray-200 text-sm truncate">
                                                                <%= namaDisplay %> (Blok <%= d.rumah %>)
                                                            </p>
                                                        </div>
                                                        <div class="flex flex-col gap-1">
                                                            <div class="flex items-center justify-between">
                                                                <p class="font-bold text-sm <%= isLunas ? 'text-green-500' : 'text-red-400' %>">
                                                                    Telah Dibayar: Rp <%= parseFloat(d.total_bayar).toLocaleString('id-ID') %>
                                                                </p>
                                                                <span class="text-xs text-green-500 opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-1">
                                                                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414-.003 6.557-5.338 11.892-11.893 11.892-1.99-.001-3.951-.5-5.688-1.448l-6.305 1.654zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981z"/></svg>
                                                                    Share
                                                                </span>
                                                            </div>
                                                            <% if(d.pending_count > 0) { %>
                                                                <p class="text-xs text-yellow-500 font-medium">
                                                                    ⏳ Menunggu Verifikasi: Rp <%= parseFloat(d.pending_bayar).toLocaleString('id-ID') %>
                                                                </p>
                                                            <% } %>
                                                        </div>
                                                    </div>
                                                    <div class="flex flex-col gap-2 items-end">
                                                        <% if (isLunas) { %>
                                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-500/20 text-green-800 dark:text-green-400">
                                                                Lunas
                                                            </span>
                                                        <% } else { %>
                                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 dark:bg-red-500/20 text-red-800 dark:text-red-400">
                                                                Terutang
                                                            </span>
                                                        <% } %>
                                                        <% if(d.pending_count > 0) { %>
                                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[10px] whitespace-nowrap font-medium bg-yellow-100 dark:bg-yellow-500/20 text-yellow-800 dark:text-yellow-500">
                                                                Pending
                                                            </span>
                                                        <% } %>
                                                    </div>
                                                </div>
                                            </div>
                                        <% }) %>
                                    </div>
                                <% } %>
                            <% } else { %>
                                <% if(donatur.length === 0) { %>
                                    <div class="text-center py-8">
                                        <svg class="mx-auto h-12 w-12 text-gray-500" fill="none" stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z">
                                            </path>
                                        </svg>
                                        <p class="mt-2 text-sm text-gray-600 dark:text-gray-400">Belum ada donatur</p>
                                    </div>
                                <% } else { %>
                                    <div class="space-y-3">
                                        <% donatur.forEach(d => { %>
                                            <div onclick="shareDonaturWA(this)" data-judul="<%= campaign.judul %>" data-nama="<%= d.nama_donatur %>" data-jumlah="Rp <%= parseFloat(d.jumlah).toLocaleString('id-ID') %>" data-tanggal="<%= moment(d.created_at).format('DD MMM YYYY HH:mm') %>" data-pesan="<%= d.pesan || '' %>" data-id="<%= d.id %>"
                                                class="block bg-gray-100 dark:bg-white/5 rounded-xl p-4 border border-white/10 hover:bg-gray-200 dark:hover:bg-white/10 transition-all cursor-pointer group">
                                                <div class="flex items-start gap-3">
                                                    <div
                                                        class="w-10 h-10 rounded-full bg-indigo-500/20 flex items-center justify-center text-indigo-400 font-bold flex-shrink-0">
                                                        <%= d.nama_donatur.charAt(0).toUpperCase() %>
                                                    </div>
                                                    <div class="flex-1 min-w-0">
                                                        <div class="flex items-center gap-2 mb-1">
                                                            <p class="font-bold text-gray-800 dark:text-gray-200 text-sm truncate">
                                                                <%= d.nama_donatur %>
                                                            </p>
                                                            <% if(d.is_anonim) { %>
                                                                <span
                                                                    class="text-xs bg-purple-500/20 text-purple-400 px-2 py-0.5 rounded-full">🕶️</span>
                                                            <% } %>
                                                        </div>
                                                        <div class="flex items-center justify-between mb-1">
                                                            <p class="<%= d.status === 'pending' ? 'text-yellow-500' : 'text-green-400' %> font-bold text-sm">
                                                                Rp <%= parseFloat(d.jumlah).toLocaleString('id-ID') %>
                                                            </p>
                                                            <% if (d.status === 'pending') { %>
                                                                <span class="text-[10px] bg-yellow-500/20 text-yellow-500 px-2 py-0.5 rounded-full">
                                                                    ⏳ Pending Verifikasi
                                                                </span>
                                                            <% } else { %>
                                                                <span class="text-[10px] bg-green-500/20 text-green-400 px-2 py-0.5 rounded-full">
                                                                    ✅ Verified
                                                                </span>
                                                            <% } %>
                                                        </div>
                                                        <% if(d.pesan) { %>
                                                            <p class="text-xs text-gray-600 dark:text-gray-400 italic line-clamp-2">"<%=
                                                                    d.pesan %>"</p>
                                                        <% } %>
                                                        <div class="flex items-center justify-between mt-1">
                                                            <p class="text-xs text-gray-500">
