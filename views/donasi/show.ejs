        <style>
            .custom-scrollbar::-webkit-scrollbar {
                width: 4px;
            }

            .custom-scrollbar::-webkit-scrollbar-track {
                background: rgba(255, 255, 255, 0.05);
            }

            .custom-scrollbar::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.1);
                border-radius: 10px;
            }
        </style>

        <script>
        function shareCampaignWA() {
            const judul = '<%= campaign.judul.replace(/'/g, "\\'") %>';
            const deskripsi = `<%= (campaign.deskripsi || '').replace(/`/g, '').replace(/\\/g, '\\\\') %>`;
            const link = 'https://gang.ambyar.biz.id/donasi/campaign/<%= campaign.id %>';
            const msg = `*${judul}*\n\n${deskripsi}\n\n\uD83D\uDD17 Selengkapnya & Donasi di sini:\n${link}`;
            window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
        }

        function shareRumahWA(el) {
            const d = el.dataset;
            const status = d.lunas === 'true' ? '\u2705 Status: LUNAS' : '\u23F3 Status: Belum Lunas';
            const msg = `*Bukti Bayar - ${d.judul}*\n\n\uD83C\uDFE0 Rumah: Blok ${d.rumah}\n\uD83D\uDC64 Nama: ${d.nama}\n\uD83D\uDCB0 Total Bayar: ${d.bayar}\n\n${status}\n\n\uD83D\uDD17 Lihat Bukti Bayar:\n${d.link}`;
            window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
        }

        function shareDonaturWA(el) {
            const d = el.dataset;
            let msg = `*Bukti Bayar - ${d.judul}*\n\n\uD83D\uDC64 Donatur: ${d.nama}\n\uD83D\uDCB0 Jumlah: ${d.jumlah}\n\uD83D\uDCC5 Tanggal: ${d.tanggal}`;
            if (d.pesan) msg += `\n\uD83D\uDCAC Pesan: ${d.pesan}`;
            msg += `\n\n\u2705 Status: Terverifikasi\n\n\uD83D\uDD17 Lihat Bukti Bayar:\nhttps://gang.ambyar.biz.id/donasi/v/${d.id}`;
            window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
        }

        function shareAllDonaturWA() {
            const tipeTarget = '<%= campaign.tipe_target %>';
            const judul = '<%= campaign.judul.replace(/'/g, "\\'") %>';
            const campaignLink = 'https://gang.ambyar.biz.id/donasi/campaign/<%= campaign.id %>';

            if (tipeTarget === 'per_rumah') {
                const cards = document.querySelectorAll('[data-rumah]');
                if (cards.length === 0) return;
                let lunas = 0, belum = 0;
                let lines = [];
                cards.forEach(c => {
                    const d = c.dataset;
                    const isLunas = d.lunas === 'true';
                    if (isLunas) lunas++; else belum++;
                    const icon = isLunas ? '\u2705' : '\u274C';
                    lines.push(`${icon} ${d.nama} (${d.rumah}) - ${d.bayar}`);
                });
                let msg = `*\uD83D\uDCCB Rekap Campaign - ${judul}*\n\n`;
                msg += `\uD83D\uDCCA Total: ${cards.length} KK\n`;
                msg += `\u2705 Lunas: ${lunas}\n`;
                msg += `\u274C Belum: ${belum}\n\n`;
                msg += lines.join('\n');
                msg += `\n\n\uD83D\uDD17 Detail:\n${campaignLink}`;
                window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
            } else {
                const cards = document.querySelectorAll('[data-nama][data-jumlah]');
                if (cards.length === 0) return;
                let lines = [];
                let total = 0;
                cards.forEach(c => {
                    const d = c.dataset;
                    lines.push(`\u2705 ${d.nama} - ${d.jumlah}`);
                });
                let msg = `*\uD83D\uDCCB Daftar Donatur - ${judul}*\n\n`;
                msg += `\uD83D\uDC65 Total Donatur: ${cards.length}\n\n`;
                msg += lines.join('\n');
                msg += `\n\n\uD83D\uDD17 Detail:\n${campaignLink}`;
                window.open('https://wa.me/?text=' + encodeURIComponent(msg), '_blank');
            }
        }
        </script>

        <%- include('../partials/footer') %>